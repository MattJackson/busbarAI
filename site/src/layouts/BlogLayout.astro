---
// Marketing-styled layout for the Busbar blog — mirrors the homepage/terms nav + footer
// so posts look like the website, not the Starlight docs.
import glyphPrimary from '../assets/busbar-primary.svg';

interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;

const GITHUB = 'https://github.com/MattJackson/busbarAI';
const DOCS = '/why-busbar/';
const YEAR = new Date().getFullYear();

// GitHub star count, fetched at build time; the inline script keeps it live for visitors.
let starsLabel = '';
try {
  const ghHeaders = { Accept: 'application/vnd.github+json', 'User-Agent': 'busbar-site' };
  if (process.env.GITHUB_TOKEN) ghHeaders.Authorization = `Bearer ${process.env.GITHUB_TOKEN}`;
  const res = await fetch('https://api.github.com/repos/MattJackson/busbarAI', { headers: ghHeaders });
  if (res.ok) {
    const n = (await res.json()).stargazers_count;
    if (typeof n === 'number') starsLabel = n >= 1000 ? (n / 1000).toFixed(1) + 'k' : String(n);
  }
} catch { /* offline build — render without a count */ }
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="color-scheme" content="light" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <meta property="og:image" content="https://getbusbar.com/og-card.png" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <header class="nav">
      <div class="wrap nav-inner">
        <a href="/" class="brand" aria-label="Busbar home">
          <img src={glyphPrimary.src} alt="" width="30" height="30" />
          <span>Busbar</span>
        </a>
        <nav class="nav-links">
          <a href={DOCS}>Docs</a>
          <a href="/blog/">Blog</a>
          <a href="/benchmark/">Benchmark</a>
          <a href="/download/">Download</a>
          <a
            href="https://discord.gg/f5XtWw4NT"
            class="nav-discord"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Discord"
          >
            <svg class="nav-discord-logo" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.317 4.369a19.79 19.79 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.211.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.1 13.1 0 0 1-1.872-.892.077.077 0 0 1-.008-.128c.126-.094.252-.192.372-.291a.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.009c.12.099.246.198.373.292a.077.077 0 0 1-.006.127 12.3 12.3 0 0 1-1.873.891.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.84 19.84 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.331c-1.183 0-2.157-1.086-2.157-2.42 0-1.333.956-2.42 2.157-2.42 1.21 0 2.176 1.096 2.157 2.42 0 1.334-.956 2.42-2.157 2.42zm7.975 0c-1.183 0-2.157-1.086-2.157-2.42 0-1.333.955-2.42 2.157-2.42 1.21 0 2.176 1.096 2.157 2.42 0 1.334-.946 2.42-2.157 2.42z"/></svg>
          </a>
          <a href={GITHUB} class="star-link" target="_blank" rel="noopener" aria-label="GitHub stars"><span class="star-count"><span data-star-count>{starsLabel}</span>★</span><svg class="gh-logo" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg></a>
        </nav>
      </div>
    </header>

    <main class="post-wrap">
      <slot />
    </main>

    <footer class="footer">
      <div class="wrap footer-inner">
        <div class="footer-brand">
          <img src={glyphPrimary.src} alt="" width="26" height="26" />
          <div>
            <strong>Busbar</strong>
            <span>The reliability layer for LLM traffic.</span>
          </div>
        </div>
        <nav class="footer-cols">
          <div>
            <h4>Docs</h4>
            <a href="/getting-started/">Getting Started</a>
            <a href="/why-busbar/">Why Busbar</a>
            <a href="/reliability/">Reliability</a>
            <a href="/benchmark/">Benchmark</a>
          </div>
          <div>
            <h4>Reference</h4>
            <a href="/protocols/">Protocols</a>
            <a href="/configuration/">Configuration</a>
            <a href="/security/">Security</a>
            <a href="/providers/">Providers</a>
          </div>
          <div>
            <h4>Project</h4>
            <a href="/blog/">Blog</a>
            <a href={GITHUB}>GitHub</a>
            <a href="/llms.txt">llms.txt</a>
          </div>
          <div>
            <h4>Legal</h4>
            <a href="/privacy/">Privacy Policy</a>
            <a href="/terms/">Terms of Service</a>
          </div>
        </nav>
      </div>
      <div class="wrap footer-base">
        <span>© {YEAR} Merseyway LLC d/b/a Busbar · Licensed AGPL-3.0</span>
        <span>One endpoint. Every LLM protocol. Losslessly.</span>
      </div>
    </footer>

    <style is:global>
      :root {
        color-scheme: light;
        --slate: #0f172a;
        --charcoal: #1e293b;
        --lime: #a3e635;
        --line: #e2e8f0;
        --muted: #64748b;
        --bg: #ffffff;
        --bg-soft: #f8fafc;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--slate);
        font-family: ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      .wrap { width: 100%; max-width: 1120px; margin: 0 auto; padding: 0 28px; }
      a { color: inherit; text-decoration: none; }
      h1, h2, h3, h4 { letter-spacing: -0.02em; line-height: 1.15; margin: 0; }

      /* NAV */
      .nav { position: sticky; top: 0; z-index: 50; background: rgba(255,255,255,0.82); backdrop-filter: saturate(180%) blur(12px); border-bottom: 1px solid var(--line); }
      .nav-inner { display: flex; align-items: center; justify-content: space-between; height: 64px; }
      .brand { display: flex; align-items: center; gap: 10px; font-weight: 700; font-size: 17px; letter-spacing: -0.01em; }
      .nav-links { display: flex; align-items: center; gap: 26px; font-size: 14.5px; font-weight: 500; }
      .nav-links a { color: var(--charcoal); transition: color 0.15s; }
      .nav-links a:hover { color: var(--slate); }
      .nav-links a.ghost { color: var(--muted); }
      .nav-links a.nav-discord { display: inline-flex; align-items: center; color: var(--muted); }
      .nav-links a.nav-discord:hover { color: #5865f2; }
      .nav-discord-logo { width: 1.25em; height: 1.25em; }
      .nav-links a.star-link { display: inline-flex; align-items: center; gap: 0.4em; color: #ca8a04; font-weight: 700; }
      .nav-links a.star-link:hover { color: #a16207; }
      .nav-links a.star-link .star-count { font-weight: 600; font-variant-numeric: tabular-nums; white-space: nowrap; }
      .nav-links a.star-link .gh-logo { width: 1.3em; height: 1.3em; color: var(--charcoal); }
      .nav-links a.star-link:hover .gh-logo { color: var(--slate); }

      /* POST */
      .post-wrap { min-height: calc(100vh - 64px - 200px); padding: 64px 28px 96px; }
      .post { max-width: 720px; margin: 0 auto; }
      .post-back { display: inline-block; font-size: 14px; color: var(--muted); margin-bottom: 28px; }
      .post-back:hover { color: var(--slate); }
      .post-meta { font-size: 13px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.04em; font-weight: 600; margin: 0 0 12px; }
      .post > h1 { font-size: clamp(30px, 4.5vw, 46px); font-weight: 800; margin: 0 0 18px; color: var(--slate); }
      .post-lede { font-size: 18px; color: #334155; line-height: 1.7; margin: 0 0 36px; padding-bottom: 28px; border-bottom: 1px solid var(--line); }

      /* PROSE (markdown body) */
      .post-body h2 { font-size: 24px; font-weight: 800; color: var(--slate); margin: 44px 0 14px; }
      .post-body h3 { font-size: 18px; font-weight: 700; color: var(--slate); margin: 32px 0 10px; }
      .post-body p { font-size: 16.5px; color: #334155; line-height: 1.8; margin: 0 0 18px; }
      .post-body ul, .post-body ol { margin: 0 0 18px; padding-left: 24px; }
      .post-body li { font-size: 16.5px; color: #334155; line-height: 1.8; margin-bottom: 8px; }
      .post-body a { color: #4d7c0f; text-decoration: underline; text-underline-offset: 3px; }
      .post-body a:hover { color: var(--slate); }
      .post-body strong { color: var(--slate); font-weight: 700; }
      .post-body em { color: var(--muted); }
      .post-body code { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.88em; background: var(--bg-soft); border: 1px solid var(--line); border-radius: 5px; padding: 1px 6px; }
      .post-body pre { background: var(--slate); color: #e2e8f0; border-radius: 10px; padding: 18px 20px; overflow-x: auto; margin: 0 0 20px; }
      .post-body pre code { background: none; border: none; padding: 0; color: inherit; font-size: 13.5px; }
      .post-body blockquote { margin: 0 0 22px; padding: 4px 0 4px 20px; border-left: 3px solid var(--lime); color: #475569; font-size: 17px; }

      /* LIST */
      .post-list { max-width: 760px; margin: 0 auto; }
      .post-list > h1 { font-size: clamp(30px, 4.5vw, 46px); font-weight: 800; margin: 0 0 8px; }
      .post-list .list-lede { font-size: 17px; color: var(--muted); margin: 0 0 40px; }
      .post-card { display: block; padding: 24px 26px; border: 1px solid var(--line); border-radius: 14px; margin-bottom: 18px; transition: border-color 0.15s, transform 0.15s; background: #fff; }
      .post-card:hover { border-color: var(--lime); transform: translateY(-2px); }
      .post-card .c-date { font-size: 12.5px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.04em; font-weight: 600; }
      .post-card .c-title { font-size: 22px; font-weight: 800; color: var(--slate); margin: 6px 0 8px; letter-spacing: -0.02em; }
      .post-card .c-desc { font-size: 15.5px; color: #475569; line-height: 1.7; margin: 0; }

      /* FOOTER */
      .footer { background: #fff; padding: 64px 0 32px; border-top: 1px solid var(--line); }
      .footer-inner { display: grid; grid-template-columns: 1fr 1.4fr; gap: 48px; padding-bottom: 40px; border-bottom: 1px solid var(--line); }
      .footer-brand { display: flex; gap: 12px; align-items: flex-start; }
      .footer-brand strong { display: block; font-size: 16px; }
      .footer-brand span { font-size: 13.5px; color: var(--muted); }
      .footer-cols { display: grid; grid-template-columns: repeat(4, 1fr); gap: 28px; }
      .footer-cols h4 { font-size: 12px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); margin-bottom: 14px; }
      .footer-cols a { display: block; font-size: 14px; color: var(--charcoal); padding: 4px 0; }
      .footer-cols a:hover { color: var(--slate); }
      .footer-base { display: flex; justify-content: space-between; padding-top: 24px; font-size: 13px; color: var(--muted); flex-wrap: wrap; gap: 10px; }

      @media (max-width: 900px) {
        .footer-inner { grid-template-columns: 1fr; gap: 32px; }
        .footer-cols { grid-template-columns: repeat(2, 1fr); }
      }
      @media (max-width: 640px) {
        body { overflow-x: hidden; }
        .nav-links { gap: 14px; }
        .nav-links a.ghost, .nav-links a[href='/benchmark/'] { display: none; }
        .footer-cols { grid-template-columns: 1fr 1fr; }
        .post-wrap { padding: 40px 16px 64px; }
      }
      @media (max-width: 420px) {
        .wrap { padding: 0 16px; }
        .nav-links { gap: 10px; font-size: 13.5px; }
      }
    </style>
    <script is:inline>
      // Keep the nav star count live (matches the homepage behavior).
      fetch('https://api.github.com/repos/MattJackson/busbarAI', {
        headers: { Accept: 'application/vnd.github+json' },
      })
        .then((r) => (r.ok ? r.json() : null))
        .then((d) => {
          if (!d || typeof d.stargazers_count !== 'number') return;
          const n = d.stargazers_count;
          const label = n >= 1000 ? (n / 1000).toFixed(1) + 'k' : String(n);
          document.querySelectorAll('.star-link [data-star-count]').forEach((el) => {
            el.textContent = label;
          });
        })
        .catch(() => {});
    </script>
  </body>
</html>
