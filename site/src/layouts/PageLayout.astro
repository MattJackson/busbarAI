---
// Shared chrome for standalone website pages (FAQ, /vs/*): homepage nav + footer,
// article typography with table support. Docs pages use Starlight; this is for
// pages that are part of the website, not the documentation.
import glyphPrimary from '../assets/busbar-primary.svg';
import Nav from '../components/Nav.astro';
import Analytics from '../components/Analytics.astro';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

const GITHUB = 'https://github.com/MattJackson/busbarAI';
const YEAR = new Date().getFullYear();

const ORG = { '@context': 'https://schema.org', '@type': 'Organization', name: 'Busbar', url: 'https://getbusbar.com', logo: 'https://getbusbar.com/favicon.svg', sameAs: ['https://github.com/MattJackson/busbarAI'] };
const WEBSITE = { '@context': 'https://schema.org', '@type': 'WebSite', name: 'Busbar', url: 'https://getbusbar.com' };
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="color-scheme" content="light" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://getbusbar.com/og-card.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://getbusbar.com/og-card.png" />
    <Analytics />
    <script type="application/ld+json" set:html={JSON.stringify(ORG)} />
    <script type="application/ld+json" set:html={JSON.stringify(WEBSITE)} />
  </head>
  <body>
    <Nav />

    <main class="page-wrap">
      <article class="page-doc">
        <slot />
      </article>
    </main>

    <footer class="footer">
      <div class="wrap footer-inner">
        <div class="footer-brand">
          <img src={glyphPrimary.src} alt="" width="26" height="26" />
          <div>
            <strong>Busbar</strong>
            <span>The reliability layer for LLM traffic.</span>
          </div>
        </div>
        <nav class="footer-cols">
          <div>
            <h4>Docs</h4>
            <a href="/getting-started/">Getting Started</a>
            <a href="/why-busbar/">Why Busbar</a>
            <a href="/faq/">FAQ</a>
            <a href="/reliability/">Reliability</a>
            <a href="/routing/">Routing</a>
            <a href="/benchmark/">Benchmark</a>
          </div>
          <div>
            <h4>Reference</h4>
            <a href="/protocols/">Protocols</a>
            <a href="/configuration/">Configuration</a>
            <a href="/security/">Security</a>
            <a href="/providers/">Providers</a>
          </div>
          <div>
            <h4>Project</h4>
            <a href="/download/">Download</a>
            <a href="/changelog/">Changelog</a>
            <a href={GITHUB}>GitHub</a>
            <a href={`${GITHUB}/blob/main/LICENSE`}>License (AGPL-3.0)</a>
            <a href="/llms.txt">llms.txt</a>
          </div>
          <div>
            <h4>Legal</h4>
            <a href="/privacy/">Privacy Policy</a>
            <a href="/terms/">Terms of Service</a>
          </div>
        </nav>
      </div>
      <div class="wrap footer-base">
        <span>© {YEAR} Merseyway LLC d/b/a Busbar</span>
        <span>One endpoint. Every LLM protocol. Losslessly.</span>
      </div>
    </footer>

    <style is:global>
      :root {
        color-scheme: light;
        --slate: #0f172a;
        --charcoal: #1e293b;
        --lime: #a3e635;
        --ink: #0b1220;
        --line: #e2e8f0;
        --muted: #64748b;
        --muted-d: #94a3b8;
        --bg: #ffffff;
        --bg-soft: #f8fafc;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--slate);
        font-family: ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto,
          Helvetica, Arial, sans-serif;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      .wrap { width: 100%; max-width: 1120px; margin: 0 auto; padding: 0 28px; }
      a { color: inherit; text-decoration: none; }
      h1, h2, h3, h4 { letter-spacing: -0.02em; line-height: 1.1; margin: 0; }

      /* NAV */
      .nav {
        position: sticky; top: 0; z-index: 50;
        background: rgba(255, 255, 255, 0.82);
        backdrop-filter: saturate(180%) blur(12px);
        border-bottom: 1px solid var(--line);
      }
      .nav-inner { display: flex; align-items: center; justify-content: space-between; height: 64px; }
      .brand { display: flex; align-items: center; gap: 10px; font-weight: 700; font-size: 17px; letter-spacing: -0.01em; }
      .nav-links { display: flex; align-items: center; gap: 26px; font-size: 14.5px; font-weight: 500; }
      .nav-links a { color: var(--charcoal); transition: color 0.15s; }
      .nav-links a:hover { color: var(--slate); }

      /* PAGE CONTENT */
      .page-wrap {
        min-height: calc(100vh - 64px - 200px);
        padding: 72px 28px 96px;
        background: var(--bg);
      }
      .page-doc {
        max-width: 780px;
        margin: 0 auto;
      }
      .page-doc .kicker {
        font-size: 13px;
        color: var(--muted);
        margin: 0 0 14px;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        font-weight: 600;
      }
      .page-doc h1 {
        font-size: clamp(28px, 4vw, 42px);
        font-weight: 800;
        margin: 0 0 24px;
        color: var(--slate);
      }
      .page-doc .intro {
        font-size: 17px;
        color: #334155;
        line-height: 1.7;
        margin: 0 0 40px;
        padding-bottom: 32px;
        border-bottom: 1px solid var(--line);
      }
      .page-doc h2 {
        font-size: 22px;
        font-weight: 700;
        color: var(--slate);
        margin: 44px 0 14px;
      }
      .page-doc h3 {
        font-size: 17px;
        font-weight: 700;
        color: var(--slate);
        margin: 30px 0 10px;
      }
      .page-doc p {
        font-size: 15.5px;
        color: #334155;
        line-height: 1.75;
        margin: 0 0 16px;
      }
      .page-doc ul {
        margin: 0 0 16px;
        padding-left: 22px;
      }
      .page-doc ul li {
        font-size: 15.5px;
        color: #334155;
        line-height: 1.75;
        margin-bottom: 8px;
      }
      .page-doc ol {
        margin: 0 0 16px;
        padding-left: 22px;
      }
      .page-doc ol li {
        font-size: 14.5px;
        color: #334155;
        line-height: 1.7;
        margin-bottom: 8px;
      }
      .page-doc a {
        color: #4d7c0f;
        text-decoration: underline;
        text-underline-offset: 3px;
      }
      .page-doc a:hover { color: var(--slate); }
      .page-doc strong { color: var(--slate); }
      .page-doc code {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.9em;
        background: var(--bg-soft);
        border: 1px solid var(--line);
        border-radius: 5px;
        padding: 1px 5px;
        color: var(--charcoal);
      }
      .page-doc .note {
        font-size: 14px;
        color: var(--muted);
        line-height: 1.7;
        background: var(--bg-soft);
        border: 1px solid var(--line);
        border-radius: 10px;
        padding: 14px 18px;
        margin: 0 0 16px;
      }
      .page-doc .note a { color: #4d7c0f; }

      /* COMPARISON TABLE */
      .page-doc .cmp {
        overflow-x: auto;
        margin: 0 0 16px;
        border: 1px solid var(--line);
        border-radius: 12px;
      }
      .page-doc table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
        line-height: 1.55;
      }
      .page-doc th {
        text-align: left;
        font-size: 12.5px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--muted);
        background: var(--bg-soft);
        padding: 12px 16px;
        border-bottom: 1px solid var(--line);
        white-space: nowrap;
      }
      .page-doc td {
        padding: 12px 16px;
        border-bottom: 1px solid var(--line);
        color: #334155;
        vertical-align: top;
      }
      .page-doc tr:last-child td { border-bottom: none; }
      .page-doc td:first-child {
        font-weight: 600;
        color: var(--slate);
        white-space: nowrap;
      }
      .page-doc td a { color: #4d7c0f; }

      /* FOOTER */
      .footer { background: #fff; padding: 64px 0 32px; border-top: 1px solid var(--line); }
      .footer-inner { display: grid; grid-template-columns: 1fr 1.4fr; gap: 48px; padding-bottom: 40px; border-bottom: 1px solid var(--line); }
      .footer-brand { display: flex; gap: 12px; align-items: flex-start; }
      .footer-brand strong { display: block; font-size: 16px; }
      .footer-brand span { font-size: 13.5px; color: var(--muted); }
      .footer-cols { display: grid; grid-template-columns: repeat(4, 1fr); gap: 28px; }
      .footer-cols h4 { font-size: 12px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); margin-bottom: 14px; }
      .footer-cols a { display: block; font-size: 14px; color: var(--charcoal); padding: 4px 0; text-decoration: none; }
      .footer-cols a:hover { color: var(--slate); }
      .footer-base { display: flex; justify-content: space-between; padding-top: 24px; font-size: 13px; color: var(--muted); flex-wrap: wrap; gap: 10px; }

      /* RESPONSIVE */
      @media (max-width: 900px) {
        .footer-inner { grid-template-columns: 1fr; gap: 32px; }
        .footer-cols { grid-template-columns: repeat(2, 1fr); }
      }
      @media (max-width: 640px) {
        html { overflow-x: clip; }
        .nav-links { gap: 14px; }
        .footer-cols { grid-template-columns: 1fr 1fr; }
        .page-wrap { padding: 40px 16px 64px; }
        .page-doc h1 { font-size: clamp(24px, 7vw, 36px); }
        .page-doc h2 { font-size: 19px; }
      }
      @media (max-width: 420px) {
        .wrap { padding: 0 16px; }
        .nav-links { gap: 10px; font-size: 13.5px; }
      }
    </style>
  </body>
</html>
