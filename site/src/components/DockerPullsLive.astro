---
// Live Docker Hub pull counts — same pattern as the GitHub star badge in Nav.astro.
// Docker Hub's API sends no CORS header, so a browser can't call it directly; a same-origin
// Cloudflare Worker at `/api/pulls?repo=<ns>/<name>` proxies it (returns `{ pull_count }`).
//
// Any element with `data-docker-repo="ns/name"` on the page is upgraded: its `[data-docker-count]`
// child (or the element itself) is refreshed to the LIVE count, rounded up Docker-Hub-style
// (2,034 -> "2.1K"). If the Worker isn't deployed / errors, the build-time baked value stands —
// so the badge is never empty and a Docker Hub hiccup can't break anything.
---
<script is:inline>
  (() => {
    const fmt = (n) => {
      if (typeof n !== 'number' || !isFinite(n) || n < 0) return null;
      if (n < 1000) return String(Math.round(n));
      const suffix = n < 1e6 ? 'K' : 'M';
      const divisor = n < 1e6 ? 100 : 1e5;        // /1000 then round UP to one decimal
      return (Math.ceil(n / divisor) / 10).toFixed(1).replace(/\.0$/, '') + suffix;
    };
    document.querySelectorAll('[data-docker-repo]').forEach(async (el) => {
      const repo = el.getAttribute('data-docker-repo');
      if (!repo) return;
      const target = el.querySelector('[data-docker-count]') || el;
      try {
        const r = await fetch('/api/pulls?repo=' + encodeURIComponent(repo));
        if (!r.ok) return;                         // baked value stands
        const s = fmt((await r.json()).pull_count);
        if (s) target.textContent = s;
      } catch { /* worker not deployed / offline → baked value stands */ }
    });
  })();
</script>
