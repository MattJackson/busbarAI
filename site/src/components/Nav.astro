---
// Single source of truth for the marketing-site header (homepage, blog, download,
// legal). Import and drop <Nav /> at the top of the body — every page stays in sync.
import glyphPrimary from '../assets/busbar-primary.svg';

const GITHUB = 'https://github.com/MattJackson/busbarAI';
const DOCS = '/why-busbar/';

// GitHub star count, fetched at build time; the inline script keeps it live for visitors.
let starsLabel = '';
try {
  const ghHeaders = { Accept: 'application/vnd.github+json', 'User-Agent': 'busbar-site' };
  if (process.env.GITHUB_TOKEN) ghHeaders.Authorization = `Bearer ${process.env.GITHUB_TOKEN}`;
  const res = await fetch('https://api.github.com/repos/MattJackson/busbarAI', { headers: ghHeaders });
  if (res.ok) {
    const n = (await res.json()).stargazers_count;
    if (typeof n === 'number') starsLabel = n >= 1000 ? (n / 1000).toFixed(1) + 'k' : String(n);
  }
} catch { /* offline build — render without a count */ }
---

<header class="nav">
  <div class="wrap nav-inner">
    <a href="/" class="brand" aria-label="Busbar home">
      <img src={glyphPrimary.src} alt="" width="30" height="30" />
      <span>Busbar</span>
    </a>
    <nav class="nav-links">
      <a href={DOCS}>Docs</a>
      <a href="/blog/">Blog</a>
      <a href="/benchmark/">Benchmark</a>
      <a href="/download/">Download</a>
      <a
        href="https://discord.gg/f5XtWw4NT"
        class="nav-discord"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Discord"
      >
        <svg class="nav-discord-logo" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.317 4.369a19.79 19.79 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.211.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.1 13.1 0 0 1-1.872-.892.077.077 0 0 1-.008-.128c.126-.094.252-.192.372-.291a.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.009c.12.099.246.198.373.292a.077.077 0 0 1-.006.127 12.3 12.3 0 0 1-1.873.891.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.84 19.84 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.331c-1.183 0-2.157-1.086-2.157-2.42 0-1.333.956-2.42 2.157-2.42 1.21 0 2.176 1.096 2.157 2.42 0 1.334-.956 2.42-2.157 2.42zm7.975 0c-1.183 0-2.157-1.086-2.157-2.42 0-1.333.955-2.42 2.157-2.42 1.21 0 2.176 1.096 2.157 2.42 0 1.334-.946 2.42-2.157 2.42z"/></svg>
      </a>
      <a href={GITHUB} class="star-link" target="_blank" rel="noopener" aria-label="GitHub stars"><span class="star-count"><span data-star-count>{starsLabel}</span>★</span><svg class="gh-logo" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg></a>
    </nav>
  </div>
</header>

<style is:global>
  .nav { position: sticky; top: 0; z-index: 50; background: rgba(255,255,255,0.82); backdrop-filter: saturate(180%) blur(12px); border-bottom: 1px solid var(--line, #e2e8f0); }
  .nav-inner { display: flex; align-items: center; justify-content: space-between; height: 64px; }
  .brand { display: flex; align-items: center; gap: 10px; font-weight: 700; font-size: 17px; letter-spacing: -0.01em; color: var(--slate, #0f172a); }
  .nav-links { display: flex; align-items: center; gap: 26px; font-size: 14.5px; font-weight: 500; }
  .nav-links a { color: var(--charcoal, #1e293b); transition: color 0.15s; text-decoration: none; }
  .nav-links a:hover { color: var(--slate, #0f172a); }
  .nav-links a.nav-discord { display: inline-flex; align-items: center; color: var(--muted, #64748b); }
  .nav-links a.nav-discord:hover { color: #5865f2; }
  .nav-discord-logo { width: 1.25em; height: 1.25em; }
  .nav-links a.star-link { display: inline-flex; align-items: center; gap: 0.4em; color: #ca8a04; font-weight: 700; }
  .nav-links a.star-link:hover { color: #a16207; }
  .nav-links a.star-link .star-count { font-weight: 600; font-variant-numeric: tabular-nums; white-space: nowrap; }
  .nav-links a.star-link .gh-logo { width: 1.3em; height: 1.3em; color: var(--charcoal, #1e293b); }
  .nav-links a.star-link:hover .gh-logo { color: var(--slate, #0f172a); }
  @media (max-width: 640px) {
    .nav-links { gap: 14px; }
    .nav-links a[href='/benchmark/'] { display: none; }
  }
  @media (max-width: 420px) {
    .nav-links { gap: 10px; font-size: 13.5px; }
  }
</style>

<script is:inline>
  fetch('https://api.github.com/repos/MattJackson/busbarAI', { headers: { Accept: 'application/vnd.github+json' } })
    .then((r) => (r.ok ? r.json() : null))
    .then((d) => {
      if (!d || typeof d.stargazers_count !== 'number') return;
      const n = d.stargazers_count;
      const label = n >= 1000 ? (n / 1000).toFixed(1) + 'k' : String(n);
      document.querySelectorAll('.star-link [data-star-count]').forEach((el) => { el.textContent = label; });
    })
    .catch(() => {});
</script>
