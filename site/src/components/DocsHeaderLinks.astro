---
// Starlight `SocialIcons` override: prepends the website's nav links (Hooks, Docs,
// FAQ, Download — same set and order as the main site header) to the docs header so
// docs pages can reach the rest of the site, then renders the default social icons
// (Discord, GitHub) after them.
import Default from '@astrojs/starlight/components/SocialIcons.astro';
---

<a class="site-link" href="/hooks/">Hooks</a>
<a class="site-link" href="/docs/why-busbar/">Docs</a>
<a class="site-link" href="/faq/">FAQ</a>
<a class="site-link" href="/download/">Download</a>
<Default><slot /></Default>

<style>
  .site-link {
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-sm);
    font-weight: 500;
    text-decoration: none;
    white-space: nowrap;
  }
  .site-link:hover {
    color: var(--sl-color-white);
  }
  @media (max-width: 50rem) {
    .site-link {
      display: none;
    }
  }
</style>
