---
import { getCollection, render } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

export async function getStaticPaths() {
  // Future-dated posts are scheduled: they only build once their date has arrived
  // (compared at build time). Redeploy on/after the date to publish.
  const now = Date.now();
  const posts = (await getCollection('blog')).filter((p) => p.data.date.valueOf() <= now);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const fmt = (d: Date) =>
  // timeZone: 'UTC' — frontmatter `date: YYYY-MM-DD` parses as UTC midnight; without it a
  // build machine west of UTC renders every post one day early.
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
---

<BlogLayout
  title={`${post.data.title} · Busbar`}
  description={post.data.description}
  datePublished={post.data.date.toISOString().slice(0, 10)}
  author={post.data.author}
  discussion={post.data.discussion}
>
  <article class="post">
    <a class="post-back" href="/blog/">← Blog</a>
    <p class="post-meta">{post.data.author} · {post.data.authorTitle} · {fmt(post.data.date)}</p>
    <h1>{post.data.title}</h1>
    <p class="post-lede">{post.data.description}</p>
    <div class="post-body">
      <Content />
    </div>
  </article>
</BlogLayout>
