---
// The Hook Store — a marketing gallery of prebuilt hooks (NOT documentation).
// Recaps what a hook is, then lists hooks as cards. Each card links to the hook's
// own detail page (/hooks/{slug}); the "Yours" CTA card links to email instead.
// Hook data is shared with the detail pages via src/data/hooks.ts.
import PageLayout from '../layouts/PageLayout.astro';
import { hooks, kindLabel } from '../data/hooks';
---

<PageLayout
  title="Hook Store — prebuilt hooks for Busbar"
  description="Prebuilt hooks for Busbar: mini-apps that run on the request path. Context compression, smart routing, PII redaction, SIEM audit — write once, run against all six protocols and every provider, with failover underneath. Browse the store or submit your own."
>
  <p class="kicker">Hook Store</p>
  <h1>Prebuilt hooks for Busbar.</h1>
  <p class="intro">
    A hook runs on the request path — a <strong>tap</strong> that watches, or a
    <strong>gate</strong> that decides: reject, restrict, route, or rewrite. Because hooks fire on
    Busbar’s normalized IR, you write one once and it runs against all six protocols and every
    provider, with failover and circuit breaking underneath it, in one hop.
    <strong>Busbar is where your AI middleware runs</strong> — and this is where you pick up the
    parts already built. Register any of them in a <code>hooks:</code> block or over the admin API.
  </p>

  <h2>In the store</h2>
  <div class="hook-store">
    {hooks.map((h) => (
      <article class:list={['store-card', { 'is-idea': h.status === 'Idea', 'is-cta': h.cta, 'is-link': !!h.href }]}>
        {h.href && (
          <a
            class="store-cover"
            href={h.href}
            aria-label={h.name}
            {...(h.external ? { target: '_blank', rel: 'noopener' } : {})}
          />
        )}
        <div class="store-head">
          {h.cta
            ? <span class="store-kind kind-any">Tap or gate</span>
            : <span class:list={['store-kind', `kind-${h.kind}`]}>{kindLabel[h.kind]}</span>}
          <span class:list={['store-status', `status-${h.status.toLowerCase().replace(' ', '-')}`]}>{h.status}</span>
        </div>
        <h3>{h.name}</h3>
        <p class="store-tag">{h.tagline}</p>
        <p class="store-body" set:html={h.body}></p>
        {h.note && <p class="store-note" set:html={h.note} />}
        {(h.repo || h.cta) && (
          <div class="store-foot">
            {h.repo && <a class="store-link" href={h.repo} target="_blank" rel="noopener">{h.linkLabel ?? 'View on GitHub →'}</a>}
            {h.cta && <a class="store-link" href="mailto:hello@getbusbar.com?subject=Hook%20for%20the%20store">Email us →</a>}
          </div>
        )}
      </article>
    ))}
  </div>

  <p class="note">
    New to hooks? Start with <a href="/docs/hooks/">the hooks docs</a> for the config shape, the
    tap/gate lifecycle, and how a hook falls back safely without ever blocking a request.
  </p>

  <style is:global>
    /* HOOK STORE — a card gallery scoped to this page. Reuses the site's lime/navy
       palette and card feel (borders, hover lift) from the homepage .feature cards. */
    .hook-store {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 18px;
      margin: 0 0 12px;
    }
    .store-card {
      position: relative;
      display: flex;
      flex-direction: column;
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 22px 22px 20px;
      transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
    }
    /* Only cards that link somewhere (is-link) or carry the CTA lift on hover —
       Idea cards are static prompts, so they stay put and show no pointer. */
    .store-card.is-link:hover,
    .store-card.is-cta:hover {
      border-color: #cbd5e1;
      box-shadow: 0 12px 30px -14px rgba(15, 23, 42, 0.16);
      transform: translateY(-2px);
    }
    /* The stretched cover link makes the whole card clickable; footer/note links
       sit above it (position + z-index) so they stay independently clickable. */
    .store-cover {
      position: absolute;
      inset: 0;
      z-index: 0;
      border-radius: inherit;
    }
    .store-card.is-link { cursor: pointer; }
    .store-card.is-link h3 { transition: color 0.15s; }
    .store-card.is-link:hover h3 { color: #4d7c0f; }
    .store-note a,
    .store-foot { position: relative; z-index: 1; }
    /* Ideas: unbuilt prompts — a softer card so they read as suggestions, not products. */
    .store-card.is-idea { background: var(--bg-soft); }
    /* The "Yours" card: lime-tinted with a green edge, so the invitation stands out. */
    .store-card.is-cta { background: #f7fee7; border-color: #d9f99d; }
    .store-card.is-cta:hover { border-color: #bef264; }
    .store-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 14px;
    }
    .store-kind {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      border-radius: 6px;
      padding: 3px 9px;
    }
    .kind-tap { color: var(--charcoal); background: #f1f5f9; border: 1px solid var(--line); }
    .kind-gate { color: #365314; background: var(--lime); }
    .kind-any { color: var(--muted); background: #fff; border: 1px dashed var(--line); }
    .store-status {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: #4d7c0f;
    }
    /* Badge states: Available (shippable, green), Coming soon (built, not yet
       linkable, amber), Example (a template to fork, amber), Idea (unbuilt
       prompt, muted), Yours (the invitation, green). */
    .store-status.status-available { color: #4d7c0f; }
    .store-status.status-coming-soon { color: #b45309; }
    .store-status.status-example { color: #b45309; }
    .store-status.status-idea { color: var(--muted); }
    .store-status.status-yours { color: #4d7c0f; }
    .store-card h3 {
      font-size: 20px;
      font-weight: 800;
      color: var(--slate);
      margin: 0 0 6px;
    }
    .store-tag {
      font-size: 14px;
      font-weight: 600;
      color: #4d7c0f;
      margin: 0 0 12px;
      line-height: 1.4;
    }
    .store-body {
      font-size: 14.5px;
      color: #475569;
      line-height: 1.65;
      margin: 0;
    }
    .store-note {
      font-size: 13.5px;
      color: var(--charcoal);
      line-height: 1.6;
      margin: 12px 0 0;
    }
    .store-foot {
      margin-top: 18px;
      padding-top: 14px;
      border-top: 1px solid var(--line);
    }
    .store-link {
      font-size: 14px;
      font-weight: 700;
      color: #4d7c0f;
      text-decoration: none;
    }
    .store-link:hover { color: var(--slate); }

    @media (max-width: 640px) {
      .hook-store { grid-template-columns: 1fr; }
    }
  </style>
</PageLayout>
