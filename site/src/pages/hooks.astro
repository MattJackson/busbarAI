---
// The Hook Store — a marketing gallery of prebuilt hooks (NOT documentation).
// Recaps what a hook is, then lists shippable hooks, each linking out to its
// GitHub repo, with a CTA to submit your own. Uses PageLayout chrome/typography;
// the card grid + CTA styles are scoped below.
import PageLayout from '../layouts/PageLayout.astro';

const GITHUB = 'https://github.com/MattJackson/busbarAI';

// One entry per hook. `kind` is tap | gate (the two hook types); `status` drives
// the badge: 'Available' (shippable, green + repo link), 'Example' (a template to
// fork, amber + repo link), 'Idea' (not built — a prompt for what's possible), and
// the final 'Yours' card (`cta: true`) which carries the submit-your-own message.
// Keep copy tight and confident, matching the site voice.
const hooks = [
  {
    name: 'Headroom',
    kind: 'gate',
    tagline: 'Context compression, on the path.',
    body: 'A rewrite gate that trims and compacts a request’s context before it ships — so a long conversation stays under the window without your app rebuilding the prompt. Written once, it works against every protocol and provider Busbar speaks.',
    repo: 'https://github.com/GetBusbar',
    status: 'Available',
    note: 'Powered by the open-source <a href="https://headroomlabs-ai.github.io/headroom/" target="_blank" rel="noopener">Headroom</a> project.',
  },
  {
    name: 'Smart Router',
    kind: 'gate',
    tagline: 'Route by cost, latency, and live load.',
    body: 'A worked example, not a finished product: a routing gate that picks the backend per request from real signals — each member’s cost, latency, live concurrency, and rate headroom. It’s a template to read, fork, and shape into the router you actually want.',
    repo: `${GITHUB}/tree/main/examples/smart-router`,
    linkLabel: 'View the example →',
    status: 'Example',
    note: 'Read the write-up: <a href="/blog/smart-routing-today/">the smart router you want is a hook</a>.',
  },
  {
    name: 'Your hook',
    kind: 'gate',
    tagline: 'Built something worth sharing?',
    body: 'A guardrail, a router, a cost meter, an audit sink — anything that runs on the path. Tell us what it does and where it lives, and we’ll list it here and link straight to your repo.',
    note: 'Email us, or open a PR against <a href="https://github.com/MattJackson/busbarAI" target="_blank" rel="noopener">the repo</a>.',
    repo: null,
    status: 'Yours',
    cta: true,
  },
  {
    name: 'PII Guard',
    kind: 'gate',
    tagline: 'Redact sensitive data before it leaves.',
    body: 'A gate that inspects and rewrites the request body, stripping or masking sensitive data — credit-card numbers, SSNs and other socials, patient records — before it reaches any provider. One guard covers every model behind Busbar, so the redaction rule lives in one place, not in every app.',
    repo: null,
    status: 'Idea',
  },
  {
    name: 'Secret Shield',
    kind: 'gate',
    tagline: 'Keep your .env out of the prompt.',
    body: 'AI coding agents load your <code>.env</code> into memory and can slip those secrets into a prompt — where they get logged, committed, or exfiltrated. A gate that scrubs the outbound body against your registered secrets catches them before the request ever leaves, for every provider at once.',
    repo: null,
    status: 'Idea',
  },
  {
    name: 'SIEM Audit',
    kind: 'tap',
    tagline: 'Every call, in your security stack.',
    body: 'A fire-and-forget tap that streams the full request and response to your SIEM or compliance archive without touching the hop. A complete, provider-agnostic audit trail for every AI call your org makes.',
    repo: null,
    status: 'Idea',
  },
  {
    name: 'Prompt Firewall',
    kind: 'gate',
    tagline: 'Block jailbreaks and injection at the door.',
    body: 'A gate that scores each request against injection and jailbreak patterns and rejects the dangerous ones before they reach a model — enforced once, in front of every provider, instead of bolted onto each app.',
    repo: null,
    status: 'Idea',
  },
  {
    name: 'Semantic Cache',
    kind: 'gate',
    tagline: 'Skip the call when you already know the answer.',
    body: 'A gate that recognises a request it has answered before and short-circuits it — returning the cached response instead of paying for the round-trip. Provider-agnostic, so the cache spans every model behind Busbar.',
    repo: null,
    status: 'Idea',
  },
];

const kindLabel = { tap: 'Tap', gate: 'Gate' };
---

<PageLayout
  title="Hook Store — prebuilt hooks for Busbar"
  description="Prebuilt hooks for Busbar: mini-apps that run on the request path. Context compression, smart routing, PII redaction, SIEM audit — write once, run against all six protocols and every provider, with failover underneath. Browse the store or submit your own."
>
  <p class="kicker">Hook Store</p>
  <h1>Prebuilt hooks for Busbar.</h1>
  <p class="intro">
    A hook runs on the request path — a <strong>tap</strong> that watches, or a
    <strong>gate</strong> that decides: reject, restrict, route, or rewrite. Because hooks fire on
    Busbar’s normalized IR, you write one once and it runs against all six protocols and every
    provider, with failover and circuit breaking underneath it, in one hop.
    <strong>Busbar is where your AI middleware runs</strong> — and this is where you pick up the
    parts already built. Register any of them in a <code>hooks:</code> block or over the admin API.
  </p>

  <h2>In the store</h2>
  <div class="hook-store">
    {hooks.map((h) => (
      <article class:list={['store-card', { 'is-idea': !h.repo && !h.cta, 'is-cta': h.cta }]}>
        <div class="store-head">
          {h.cta
            ? <span class="store-kind kind-any">Tap or gate</span>
            : <span class:list={['store-kind', `kind-${h.kind}`]}>{kindLabel[h.kind]}</span>}
          <span class:list={['store-status', `status-${h.status.toLowerCase().replace(' ', '-')}`]}>{h.status}</span>
        </div>
        <h3>{h.name}</h3>
        <p class="store-tag">{h.tagline}</p>
        <p class="store-body">{h.body}</p>
        {h.note && <p class="store-note" set:html={h.note} />}
        {(h.repo || h.cta) && (
          <div class="store-foot">
            {h.repo && <a class="store-link" href={h.repo} target="_blank" rel="noopener">{h.linkLabel ?? 'View on GitHub →'}</a>}
            {h.cta && <a class="store-link" href="mailto:hello@getbusbar.com?subject=Hook%20for%20the%20store">Email us →</a>}
          </div>
        )}
      </article>
    ))}
  </div>

  <p class="note">
    New to hooks? Start with <a href="/docs/hooks/">the hooks docs</a> for the config shape, the
    tap/gate lifecycle, and how a hook falls back safely without ever blocking a request.
  </p>

  <style is:global>
    /* HOOK STORE — a card gallery scoped to this page. Reuses the site's lime/navy
       palette and card feel (borders, hover lift) from the homepage .feature cards. */
    .hook-store {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 18px;
      margin: 0 0 12px;
    }
    .store-card {
      display: flex;
      flex-direction: column;
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 22px 22px 20px;
      transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
    }
    .store-card:hover {
      border-color: #cbd5e1;
      box-shadow: 0 12px 30px -14px rgba(15, 23, 42, 0.16);
      transform: translateY(-2px);
    }
    /* Ideas: unbuilt prompts — a softer card so they read as suggestions, not products. */
    .store-card.is-idea { background: var(--bg-soft); }
    /* The "Yours" card: lime-tinted with a green edge, so the invitation stands out. */
    .store-card.is-cta { background: #f7fee7; border-color: #d9f99d; }
    .store-card.is-cta:hover { border-color: #bef264; }
    .store-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 14px;
    }
    .store-kind {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      border-radius: 6px;
      padding: 3px 9px;
    }
    .kind-tap { color: var(--charcoal); background: #f1f5f9; border: 1px solid var(--line); }
    .kind-gate { color: #365314; background: var(--lime); }
    .kind-any { color: var(--muted); background: #fff; border: 1px dashed var(--line); }
    .store-status {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: #4d7c0f;
    }
    /* Badge states: Available (shippable, green), Example (a template to fork,
       amber), Idea (unbuilt prompt, muted), Yours (the invitation, green). */
    .store-status.status-available { color: #4d7c0f; }
    .store-status.status-example { color: #b45309; }
    .store-status.status-idea { color: var(--muted); }
    .store-status.status-yours { color: #4d7c0f; }
    .store-card h3 {
      font-size: 20px;
      font-weight: 800;
      color: var(--slate);
      margin: 0 0 6px;
    }
    .store-tag {
      font-size: 14px;
      font-weight: 600;
      color: #4d7c0f;
      margin: 0 0 12px;
      line-height: 1.4;
    }
    .store-body {
      font-size: 14.5px;
      color: #475569;
      line-height: 1.65;
      margin: 0;
    }
    .store-note {
      font-size: 13.5px;
      color: var(--charcoal);
      line-height: 1.6;
      margin: 12px 0 0;
    }
    .store-foot {
      margin-top: 18px;
      padding-top: 14px;
      border-top: 1px solid var(--line);
    }
    .store-link {
      font-size: 14px;
      font-weight: 700;
      color: #4d7c0f;
      text-decoration: none;
    }
    .store-link:hover { color: var(--slate); }

    @media (max-width: 640px) {
      .hook-store { grid-template-columns: 1fr; }
    }
  </style>
</PageLayout>
