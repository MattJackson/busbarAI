---
// Busbar Terms of Service, standalone Astro page matching homepage nav + footer styling.
import glyphPrimary from '../assets/busbar-primary.svg';
import Nav from '../components/Nav.astro';
import Analytics from '../components/Analytics.astro';

const GITHUB = 'https://github.com/MattJackson/busbarAI';
const LICENSE = `${GITHUB}/blob/main/LICENSE`;
const DOCS = '/why-busbar/';
const YEAR = new Date().getFullYear();

const ORG = { '@context': 'https://schema.org', '@type': 'Organization', name: 'Busbar', url: 'https://getbusbar.com', logo: 'https://getbusbar.com/favicon.svg', sameAs: ['https://github.com/MattJackson/busbarAI'] };
const WEBSITE = { '@context': 'https://schema.org', '@type': 'WebSite', name: 'Busbar', url: 'https://getbusbar.com' };
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Terms of Service, Busbar</title>
    <meta
      name="description"
      content="Terms of Service for the getbusbar.com website, operated by Merseyway LLC d/b/a Busbar."
    />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="color-scheme" content="light" />
    <Analytics />
    <script type="application/ld+json" set:html={JSON.stringify(ORG)} />
    <script type="application/ld+json" set:html={JSON.stringify(WEBSITE)} />
  </head>
  <body>
    <Nav />

    <main class="legal-wrap">
      <div class="legal-doc">
        <p class="last-updated">Last updated: June 2026</p>
        <h1>Terms of Service</h1>
        <p class="intro">
          These Terms of Service ("Terms") govern your use of the
          <strong>getbusbar.com</strong> website, operated by
          <strong>Merseyway LLC d/b/a Busbar</strong> ("Busbar", "we", "us", or "our"),
          30 N Gould St Ste R, Sheridan, WY 82801, USA. By accessing this website you
          agree to these Terms.
        </p>

        <h2>1. The software is licensed separately</h2>
        <p>
          The Busbar software is open-source and licensed under the
          <a href={LICENSE}>GNU Affero General Public License v3.0 or later (AGPL-3.0-or-later)</a>.
          These Terms cover your use of this website only, they do not modify or supplement
          the AGPL license that governs your rights to use, copy, modify, and distribute the
          Busbar software. Your rights and obligations with respect to the software are
          determined solely by the AGPL-3.0-or-later license.
        </p>

        <h2>2. No warranty</h2>
        <p>
          This website is provided <strong>"as is"</strong> and <strong>"as available"</strong>,
          without warranty of any kind, express or implied, including but not limited to
          warranties of merchantability, fitness for a particular purpose, or
          non-infringement. We do not warrant that the website will be uninterrupted,
          error-free, or free of harmful components.
        </p>
        <p>
          The Busbar software is likewise provided without warranty, as set out in the
          AGPL-3.0-or-later license.
        </p>

        <h2>3. Limitation of liability</h2>
        <p>
          To the maximum extent permitted by applicable law, Merseyway LLC and its officers,
          employees, and agents will not be liable for any indirect, incidental, special,
          consequential, or punitive damages, including loss of profits, data, or goodwill,
          arising out of or in connection with your use of (or inability to use) this website,
          even if we have been advised of the possibility of such damages.
        </p>
        <p>
          Some jurisdictions do not allow the exclusion or limitation of certain damages, so
          the above limitation may not apply to you in full.
        </p>

        <h2>4. Acceptable use</h2>
        <p>
          When using this website you agree not to:
        </p>
        <ul>
          <li>Attempt to gain unauthorised access to any part of the website or its underlying systems</li>
          <li>Transmit malware, spam, or other harmful or disruptive content</li>
          <li>Use automated tools to scrape or crawl the website in a manner that places unreasonable load on our infrastructure</li>
          <li>Misrepresent your identity or affiliation with any person or organisation</li>
          <li>Use the website for any unlawful purpose or in violation of any applicable law or regulation</li>
        </ul>

        <h2>5. Trademarks</h2>
        <p>
          "Busbar" and the Busbar logo are trademarks of Merseyway LLC. Nothing in the
          AGPL-3.0-or-later license or in these Terms grants you any right to use our
          trademarks, trade names, or logos without our prior written permission.
        </p>

        <h2>6. Third-party links</h2>
        <p>
          This website may contain links to third-party websites, including GitHub. We are
          not responsible for the content, privacy practices, or terms of any third-party
          site. Links do not imply endorsement.
        </p>

        <h2>7. Governing law</h2>
        <p>
          These Terms are governed by and construed in accordance with the laws of the
          <strong>State of Wyoming, USA</strong>, without regard to its conflict-of-law
          principles. Any dispute arising from these Terms or your use of this website
          will be subject to the exclusive jurisdiction of the state and federal courts
          located in Wyoming.
        </p>

        <h2>8. Changes to these Terms</h2>
        <p>
          We may update these Terms from time to time. The "Last updated" date at the top
          of this page reflects the date of the most recent revision. Continued use of
          this website after a revision constitutes your acceptance of the updated Terms.
        </p>

        <h2>9. Contact</h2>
        <p>
          For questions about these Terms, contact us at:
        </p>
        <address>
          <strong>Merseyway LLC d/b/a Busbar</strong><br />
          Email: <a href="mailto:hello@getbusbar.com">hello@getbusbar.com</a><br />
          30 N Gould St Ste R<br />
          Sheridan, WY 82801, USA
        </address>
      </div>
    </main>

    <footer class="footer">
      <div class="wrap footer-inner">
        <div class="footer-brand">
          <img src={glyphPrimary.src} alt="" width="26" height="26" />
          <div>
            <strong>Busbar</strong>
            <span>The reliability layer for LLM traffic.</span>
          </div>
        </div>
        <nav class="footer-cols">
          <div>
            <h4>Docs</h4>
            <a href="/getting-started/">Getting Started</a>
            <a href="/why-busbar/">Why Busbar</a>
            <a href="/reliability/">Reliability</a>
            <a href="/routing/">Routing</a>
            <a href="/benchmark/">Benchmark</a>
          </div>
          <div>
            <h4>Reference</h4>
            <a href="/protocols/">Protocols</a>
            <a href="/configuration/">Configuration</a>
            <a href="/security/">Security</a>
            <a href="/providers/">Providers</a>
          </div>
          <div>
            <h4>Project</h4>
            <a href={GITHUB}>GitHub</a>
            <a href={`${GITHUB}/blob/main/LICENSE`}>License (AGPL-3.0)</a>
            <a href="/llms.txt">llms.txt</a>
          </div>
          <div>
            <h4>Legal</h4>
            <a href="/privacy/">Privacy Policy</a>
            <a href="/terms/">Terms of Service</a>
          </div>
        </nav>
      </div>
      <div class="wrap footer-base">
        <span>© {YEAR} Merseyway LLC d/b/a Busbar · Licensed AGPL-3.0</span>
        <span>One endpoint. Every LLM protocol. Losslessly.</span>
      </div>
    </footer>

    <style is:global>
      :root {
        color-scheme: light;
        --slate: #0f172a;
        --charcoal: #1e293b;
        --lime: #a3e635;
        --ink: #0b1220;
        --line: #e2e8f0;
        --muted: #64748b;
        --muted-d: #94a3b8;
        --bg: #ffffff;
        --bg-soft: #f8fafc;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--slate);
        font-family: ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto,
          Helvetica, Arial, sans-serif;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      .wrap { width: 100%; max-width: 1120px; margin: 0 auto; padding: 0 28px; }
      a { color: inherit; text-decoration: none; }
      h1, h2, h3, h4 { letter-spacing: -0.02em; line-height: 1.1; margin: 0; }

      /* NAV */
      .nav {
        position: sticky; top: 0; z-index: 50;
        background: rgba(255, 255, 255, 0.82);
        backdrop-filter: saturate(180%) blur(12px);
        border-bottom: 1px solid var(--line);
      }
      .nav-inner { display: flex; align-items: center; justify-content: space-between; height: 64px; }
      .brand { display: flex; align-items: center; gap: 10px; font-weight: 700; font-size: 17px; letter-spacing: -0.01em; }
      .nav-links { display: flex; align-items: center; gap: 26px; font-size: 14.5px; font-weight: 500; }
      .nav-links a { color: var(--charcoal); transition: color 0.15s; }
      .nav-links a:hover { color: var(--slate); }
      .nav-links a.ghost { color: var(--muted); }

      /* LEGAL CONTENT */
      .legal-wrap {
        min-height: calc(100vh - 64px - 200px);
        padding: 72px 28px 96px;
        background: var(--bg);
      }
      .legal-doc {
        max-width: 720px;
        margin: 0 auto;
      }
      .last-updated {
        font-size: 13px;
        color: var(--muted);
        margin: 0 0 14px;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        font-weight: 600;
      }
      .legal-doc h1 {
        font-size: clamp(28px, 4vw, 42px);
        font-weight: 800;
        margin: 0 0 24px;
        color: var(--slate);
      }
      .legal-doc .intro {
        font-size: 17px;
        color: #334155;
        line-height: 1.7;
        margin: 0 0 40px;
        padding-bottom: 32px;
        border-bottom: 1px solid var(--line);
      }
      .legal-doc h2 {
        font-size: 19px;
        font-weight: 700;
        color: var(--slate);
        margin: 40px 0 14px;
      }
      .legal-doc p {
        font-size: 15.5px;
        color: #334155;
        line-height: 1.75;
        margin: 0 0 16px;
      }
      .legal-doc ul {
        margin: 0 0 16px;
        padding-left: 22px;
      }
      .legal-doc ul li {
        font-size: 15.5px;
        color: #334155;
        line-height: 1.75;
        margin-bottom: 6px;
      }
      .legal-doc a {
        color: #4d7c0f;
        text-decoration: underline;
        text-underline-offset: 3px;
      }
      .legal-doc a:hover {
        color: var(--slate);
      }
      .legal-doc address {
        font-style: normal;
        font-size: 15.5px;
        color: #334155;
        line-height: 1.9;
        background: var(--bg-soft);
        border: 1px solid var(--line);
        border-radius: 10px;
        padding: 18px 22px;
        margin-top: 12px;
      }
      .legal-doc strong { color: var(--slate); }

      /* FOOTER */
      .footer { background: #fff; padding: 64px 0 32px; border-top: 1px solid var(--line); }
      .footer-inner { display: grid; grid-template-columns: 1fr 1.4fr; gap: 48px; padding-bottom: 40px; border-bottom: 1px solid var(--line); }
      .footer-brand { display: flex; gap: 12px; align-items: flex-start; }
      .footer-brand strong { display: block; font-size: 16px; }
      .footer-brand span { font-size: 13.5px; color: var(--muted); }
      .footer-cols { display: grid; grid-template-columns: repeat(4, 1fr); gap: 28px; }
      .footer-cols h4 { font-size: 12px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); margin-bottom: 14px; }
      .footer-cols a { display: block; font-size: 14px; color: var(--charcoal); padding: 4px 0; text-decoration: none; }
      .footer-cols a:hover { color: var(--slate); }
      .footer-base { display: flex; justify-content: space-between; padding-top: 24px; font-size: 13px; color: var(--muted); flex-wrap: wrap; gap: 10px; }

      /* RESPONSIVE */
      @media (max-width: 900px) {
        .footer-inner { grid-template-columns: 1fr; gap: 32px; }
        .footer-cols { grid-template-columns: repeat(2, 1fr); }
      }
      @media (max-width: 640px) {
        html { overflow-x: clip; }
        .nav-links { gap: 14px; }
        .footer-cols { grid-template-columns: 1fr 1fr; }
        .legal-wrap { padding: 40px 16px 64px; }
        .legal-doc h1 { font-size: clamp(24px, 7vw, 36px); }
        .legal-doc h2 { font-size: 17px; }
      }
      @media (max-width: 420px) {
        .wrap { padding: 0 16px; }
        .nav-links { gap: 10px; font-size: 13.5px; }
      }
    </style>
  </body>
</html>
