---
// Busbar marketing homepage, a standalone Astro page (full design control),
// coexisting with the Starlight docs served at /getting-started/, /reliability/, etc.
// src/pages/ takes routing precedence over the Starlight content collection, so this
// owns "/" while every docs route is untouched.
import glyphLime from '../assets/busbar-glyph-lime.svg';
import glyphWhite from '../assets/busbar-glyph-white.svg';
import glyphPrimary from '../assets/busbar-primary.svg';
import Nav from '../components/Nav.astro';
import Analytics from '../components/Analytics.astro';

const GITHUB = 'https://github.com/MattJackson/busbarAI';
const DOCS = '/docs/why-busbar/';

const ORG = { '@context': 'https://schema.org', '@type': 'Organization', name: 'Busbar', url: 'https://getbusbar.com', logo: 'https://getbusbar.com/favicon.svg', sameAs: ['https://github.com/MattJackson/busbarAI'] };
const WEBSITE = { '@context': 'https://schema.org', '@type': 'WebSite', name: 'Busbar', url: 'https://getbusbar.com' };
const SOFTWARE = { '@context': 'https://schema.org', '@type': 'SoftwareApplication', name: 'Busbar', applicationCategory: 'DeveloperApplication', operatingSystem: 'Linux, macOS, Windows', offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' }, url: 'https://getbusbar.com', description: 'The reliability and fidelity layer for multi-model AI traffic, lossless cross-protocol translation, fault-aware circuit breaking, and in-flight failover in one static Rust binary.' };

const protocols = ['OpenAI', 'Anthropic', 'Gemini', 'Bedrock', 'Cohere', 'Responses'];

const features = [
  {
    title: 'Lossless cross-protocol translation',
    body: 'Six wire protocols, native on both sides, bridged through one internal format rich enough to hold every protocol’s features. Anthropic thinking blocks, structured-output schemas, and Bedrock tool use survive the hop. Nothing gets flattened to OpenAI shape.',
    enables: 'Point whatever SDK your code already speaks at one URL, and reach every model through it.',
  },
  {
    title: 'Fault-aware failover & circuit breaking',
    body: 'A circuit breaker on every provider lane knows whose fault each failure was (a provider outage, your bad request, a context overflow, a revoked key) and treats each one differently instead of retrying into a wall. A failed lane reroutes mid-flight, before your client sees a single byte.',
    enables: 'A flaky provider is pulled and probed back gently; a rate-limit storm on one lane never starves the healthy ones.',
  },
  {
    title: 'A programmable request path',
    body: 'Routing is the first hook. Pick a built-in policy (weighted, cheapest, fastest, least_busy, usage) or bring your own as a webhook in any language, or as a sandboxed Rhai script. Policies see each member’s cost, latency, live concurrency, budget, and rate headroom. A slow or broken hook falls back; it never blocks a request.',
    enables: 'The same fail-safe machinery is built to carry PII-steering, audit, and guardrails: your own logic on the request path, in any language.',
  },
  {
    title: 'Governance & hard budget caps',
    body: 'Issue virtual keys with daily, monthly, or all-time spend caps and per-key RPM/TPM limits. A request that would break its cap is rejected before it is forwarded: the budget check and the charge are one atomic operation, so a concurrent burst can’t race past the limit. Scope keys to pools, revoke instantly, query spend via the admin API.',
    enables: 'Budgets enforced before the request runs, not discovered on the invoice.',
  },
  {
    title: 'Native TLS & mutual TLS',
    body: 'Busbar terminates TLS itself (cert and key in config, no reverse proxy required). Turn on mTLS and a client must present a certificate signed by your CA; anyone without one is rejected at the handshake, before any bearer-token check is reached.',
    enables: 'Zero-trust ingress without standing up a service mesh.',
  },
  {
    title: 'A single Rust binary you own',
    body: 'One static binary with no runtime, no sidecar, and no interpreter in the request path. It ships for Linux and macOS (Intel and ARM) and Windows (Intel). Provider keys move out of every app deployment into one place; your app carries only a Busbar token. Prometheus /metrics and OTLP traces built in.',
    enables: 'Your infrastructure, your keys, your data path. Rotating an upstream key is one restart, not a deploy sweep.',
  },
];

const trust = [
  { k: 'One binary', v: 'No Python runtime' },
  { k: 'Hardened', v: 'SSRF guards · constant-time auth' },
  { k: 'Cross-platform', v: 'Linux · macOS · Windows · ARM' },
  { k: 'Measured', v: '38 µs added latency · verifiable per-request' },
];

// Code blocks rendered via set:html so literal { } braces aren't parsed as Astro expressions.
const heroCode = `<span class="cm"># Already speak OpenAI? Just swap the base URL.</span>
<span class="del">- client = OpenAI(api_key=OPENAI_KEY)</span>
<span class="add">+ client = OpenAI(</span>
<span class="add">+     api_key=BUSBAR_TOKEN,</span>
<span class="add">+     base_url=<span class="str">"http://busbar:8080"</span>,</span>
<span class="add">+ )</span>

  <span class="cm"># "fast" = a pool you define in config:</span>
  <span class="cm"># 80% Claude / 20% GPT-4o, Gemini on failover.</span>
  client.chat.completions.create(
      model=<span class="str">"fast"</span>,
      messages=[{<span class="str">"role"</span>: <span class="str">"user"</span>, <span class="str">"content"</span>: <span class="str">"Hi!"</span>}],
  )`;

const qsInstall = `curl -fsSL https://getbusbar.com/install.sh | sh`;
const qsConfig = `providers:
  anthropic:
    api_key_env: ANTHROPIC_KEY

models:
  claude-sonnet:
    provider: anthropic
    max_concurrent: 10`;
const qsRun = `export ANTHROPIC_KEY=sk-ant-...
BUSBAR_PROVIDERS=./providers.yaml \\
BUSBAR_CONFIG=./config.yaml busbar   <span class="cm"># serving on :8080</span>`;
const qsRequest = `curl localhost:8080/v1/chat/completions \\
  -d '{"model":"claude-sonnet",
       "messages":[{"role":"user","content":"hi"}]}'`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Busbar: One endpoint. Every LLM protocol. Losslessly.</title>
    <meta
      name="description"
      content="Self-hosted LLM gateway and control plane in a single Rust binary. One endpoint speaks OpenAI, Anthropic, Gemini, Bedrock, Cohere, and Responses, routing to weighted pools, translating losslessly, and failing over through provider outages before your user sees a byte."
    />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta property="og:title" content="Busbar: One endpoint. Every LLM protocol. Losslessly." />
    <meta
      property="og:description"
      content="The self-hosted control plane for LLM traffic, in a single Rust binary. Speaks six wire protocols, routes to weighted pools, and fails over through outages."
    />
    <meta property="og:image" content="https://getbusbar.com/og-card.png" />
    <meta property="og:url" content="https://getbusbar.com/" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://getbusbar.com/og-card.png" />
    <meta name="color-scheme" content="light" />
    <link rel="canonical" href={new URL(Astro.url.pathname, "https://getbusbar.com")} />
    <Analytics />
    <script type="application/ld+json" set:html={JSON.stringify(ORG)} />
    <script type="application/ld+json" set:html={JSON.stringify(WEBSITE)} />
    <script type="application/ld+json" set:html={JSON.stringify(SOFTWARE)} />
  </head>
  <body>
    <Nav />

    <!-- HERO -->
    <section class="hero">
      <div class="wrap hero-grid">
        <div class="hero-copy">
          <div class="eyebrow"><span class="eyebrow-full">The self-hosted LLM control plane · single Rust binary</span><span class="eyebrow-short">Self-hosted · single Rust binary</span></div>
          <h1>One endpoint.<br /><span class="accent">Every LLM protocol.</span><br />Losslessly.</h1>
          <p class="lede">
            Busbar sits between your application and every provider it calls. Point any SDK at one
            URL, it routes to the backends you choose, translates across six wire protocols without
            dropping a feature, and keeps serving through provider failures before your user sees a byte.
          </p>
          <div class="cta-row">
            <a href="/docs/getting-started/" class="btn">Get started</a>
            <a href="/download/" class="btn btn-ghost">Download</a>
            <a href={DOCS} class="btn btn-text">Read the docs →</a>
          </div>
          <div class="proto-row" aria-label="Supported protocols">
            {protocols.map((p) => <span class="proto">{p}</span>)}
          </div>
        </div>

        <div class="hero-demo" aria-hidden="false">
          <div class="code-card">
            <div class="code-head">
              <span class="dot"></span><span class="dot"></span><span class="dot"></span>
              <span class="code-file">app.py</span>
            </div>
            <pre><code set:html={heroCode}></code></pre>
          </div>
          <p class="demo-note">
            Left as OpenAI, may have been served by Anthropic, came back as OpenAI, translated both
            ways. If a lane returned 429 mid-flight, Busbar rerouted before your client saw a byte.
            <strong>The model name is a config value, not a code dependency.</strong>
          </p>
        </div>
      </div>
    </section>

    <!-- CORE IDEA -->
    <section class="core wrap">
      <div class="core-inner">
        <h2>Any protocol in. Any backend out.</h2>
        <p>
          You define a model name and the backends behind it. Busbar accepts <em>any</em> input
          protocol (OpenAI, Anthropic, Gemini, Bedrock, Cohere, Responses) and routes and
          translates accordingly. One model name, reachable by every client; you choose what runs
          behind it. This is not another proxy with a long model list. There is
          no privileged protocol and no model list to be on: providers speak about six languages
          between them, Busbar speaks all six, so a new model works the day it ships. <strong>The
          model name is a config value, not a release note.</strong> See for yourself:
          <a href="/build/">pick your models, get the config</a>.
        </p>
      </div>
    </section>

    <!-- HOW IT WORKS DIAGRAM -->
    <section class="flow wrap">
      <h2 class="section-title">How it works</h2>
      <div class="diagram">
        <div class="col col-clients">
          <div class="col-label">Any client · 6 protocols</div>
          <div class="node">OpenAI · Anthropic</div>
          <div class="node">Gemini · Bedrock</div>
          <div class="node">Cohere · Responses</div>
        </div>

        <div class="link-zone">
          <span class="hop-tls">TLS · mTLS</span>
          <svg viewBox="0 0 120 220" preserveAspectRatio="none" aria-hidden="true">
            <path d="M0 30 C 70 30, 50 110, 120 110" />
            <path d="M0 110 H 120" />
            <path d="M0 190 C 70 190, 50 110, 120 110" />
          </svg>
        </div>

        <div class="col col-busbar">
          <div class="busbar-box">
            <div class="bb-title"><img src={glyphWhite.src} alt="" width="22" height="22" /> Busbar</div>
            <div class="bb-tags">
              <span>translate</span><span>route</span><span>failover</span><span>govern</span>
            </div>
            <div class="bb-sub">one endpoint · :8080</div>
          </div>
          <svg class="hook-line" viewBox="0 0 2 34" preserveAspectRatio="none" aria-hidden="true"><line x1="1" y1="0" x2="1" y2="34" /></svg>
          <div class="hook-out">Hooks · your policy on the path</div>
        </div>

        <div class="link-zone" aria-hidden="true">
          <svg viewBox="0 0 120 220" preserveAspectRatio="none">
            <path d="M0 110 C 70 110, 50 30, 120 30" />
            <path d="M0 110 H 120" />
            <path d="M0 110 C 70 110, 50 190, 120 190" />
          </svg>
        </div>

        <div class="col col-providers">
          <div class="col-label">Backends · any provider</div>
          <div class="node">Anthropic · OpenAI</div>
          <div class="node">Gemini · Bedrock</div>
          <div class="node node-more">+ more</div>
        </div>
      </div>
    </section>

    <!-- FEATURES -->
    <section class="features wrap">
      <h2 class="section-title">Built reliability-first</h2>
      <div class="feature-grid">
        {features.map((f) => (
          <article class="feature">
            <h3>{f.title}</h3>
            <p set:html={f.body}></p>
            <p class="enables"><span>Enables</span> <span set:html={f.enables}></span></p>
          </article>
        ))}
      </div>
    </section>

    <!-- ONE PROVIDER TODAY -->
    <section class="core wrap">
      <div class="core-inner">
        <h2>Already committed to one provider?</h2>
        <p>
          Busbar pays for itself before the second provider exists. Run it as a straight
          passthrough and your posture improves the same day: the provider key moves out of every
          app deployment, a runaway loop hits your cap instead of your bill, and every request
          shows up in your metrics. When the constraint moves, a new backend is a config lane, not
          a rewrite. <a href="/faq/#one-provider">Why add a gateway now</a> · <a
          href="/blog/valuable-before-the-second-provider/">the day it paid off</a>
        </p>
      </div>
    </section>

    <!-- QUICKSTART -->
    <section class="quickstart">
      <div class="wrap qs-grid">
        <div class="qs-copy">
          <h2>Running in 60 seconds</h2>
          <p>
            One command pulls the binary and the provider catalog. Write a minimal config, point an
            SDK at it, and you’re serving. No sudo, no runtime, no virtualenv.
          </p>
          <a href="/docs/getting-started/" class="btn">Full walkthrough →</a>
        </div>
        <div class="qs-steps">
          <div class="qs-block">
            <span class="qs-tag">install</span>
            <pre><code set:html={qsInstall}></code></pre>
          </div>
          <div class="qs-block">
            <span class="qs-tag">config.yaml</span>
            <pre><code set:html={qsConfig}></code></pre>
          </div>
          <div class="qs-block">
            <span class="qs-tag">run</span>
            <pre><code set:html={qsRun}></code></pre>
          </div>
          <div class="qs-block">
            <span class="qs-tag">request</span>
            <pre><code set:html={qsRequest}></code></pre>
          </div>
        </div>
      </div>
    </section>

    <!-- TRUST ROW -->
    <section class="trust">
      <div class="wrap trust-grid">
        {trust.map((t) => (
          <div class="trust-item">
            <div class="trust-k">{t.k}</div>
            <div class="trust-v">{t.v}</div>
          </div>
        ))}
      </div>
      <div class="wrap logo-cta">
        <p>
          Using Busbar? We’d love to put your logo here.
          <a href="mailto:hello@getbusbar.com?subject=Featured%20logo%20on%20getbusbar.com">hello@getbusbar.com</a>
        </p>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="footer">
      <div class="wrap footer-inner">
        <div class="footer-brand">
          <img src={glyphPrimary.src} alt="" width="26" height="26" />
          <div>
            <strong>Busbar</strong>
            <span>The reliability layer for LLM traffic.</span>
          </div>
        </div>
        <nav class="footer-cols">
          <div>
            <h4>Docs</h4>
            <a href="/docs/getting-started/">Getting Started</a>
            <a href="/docs/why-busbar/">Why Busbar</a>
            <a href="/faq/">FAQ</a>
            <a href="/build/">Config builder</a>
            <a href="/docs/reliability/">Reliability</a>
            <a href="/docs/routing/">Routing</a>
            <a href="/docs/benchmark/">Benchmark</a>
          </div>
          <div>
            <h4>Reference</h4>
            <a href="/docs/protocols/">Protocols</a>
            <a href="/docs/configuration/">Configuration</a>
            <a href="/docs/security/">Security</a>
            <a href="/docs/providers/">Providers</a>
          </div>
          <div>
            <h4>Project</h4>
            <a href="/download/">Download</a>
            <a href="/docs/changelog/">Changelog</a>
            <a href={GITHUB}>GitHub</a>
            <a href={`${GITHUB}/blob/main/LICENSE`}>License (AGPL-3.0)</a>
            <a href="/llms.txt">llms.txt</a>
          </div>
          <div>
            <h4>Legal</h4>
            <a href="/privacy/">Privacy Policy</a>
            <a href="/terms/">Terms of Service</a>
          </div>
        </nav>
      </div>
      <div class="wrap footer-base">
        <span>© {new Date().getFullYear()} Merseyway LLC d/b/a Busbar</span>
        <span>One endpoint. Every LLM protocol. Losslessly.</span>
      </div>
    </footer>

    <style is:global>
      :root {
        color-scheme: light;
        --slate: #0f172a;
        --charcoal: #1e293b;
        --lime: #a3e635;
        --ink: #0b1220;
        --line: #e2e8f0;
        --muted: #64748b;
        --muted-d: #94a3b8;
        --bg: #ffffff;
        --bg-soft: #f8fafc;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; overflow-x: clip; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--slate);
        font-family: ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto,
          Helvetica, Arial, sans-serif;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      .wrap { width: 100%; max-width: 1120px; margin: 0 auto; padding: 0 28px; }
      a { color: inherit; text-decoration: none; }
      h1, h2, h3, h4 { letter-spacing: -0.02em; line-height: 1.1; margin: 0; }
      code, pre { font-family: ui-monospace, 'SF Mono', 'JetBrains Mono', Menlo, monospace; }

      /* NAV */
      .nav {
        position: sticky; top: 0; z-index: 50;
        background: rgba(255, 255, 255, 0.82);
        backdrop-filter: saturate(180%) blur(12px);
        border-bottom: 1px solid var(--line);
      }
      .nav-inner { display: flex; align-items: center; justify-content: space-between; height: 64px; }
      .brand { display: flex; align-items: center; gap: 10px; font-weight: 700; font-size: 17px; letter-spacing: -0.01em; }
      .nav-links { display: flex; align-items: center; gap: 26px; font-size: 14.5px; font-weight: 500; }
      .nav-links a { color: var(--charcoal); transition: color 0.15s; }
      .nav-links a:hover { color: var(--slate); }
      .nav-links a.ghost { color: var(--muted); }

      .btn {
        display: inline-flex; align-items: center; justify-content: center;
        background: var(--slate); color: #fff; font-weight: 600; font-size: 15px;
        padding: 11px 20px; border-radius: 9px; border: 1px solid var(--slate);
        transition: transform 0.12s ease, box-shadow 0.15s ease, background 0.15s;
      }
      .btn:hover { transform: translateY(-1px); box-shadow: 0 8px 22px rgba(15, 23, 42, 0.18); }
      .btn-sm { padding: 8px 15px; font-size: 14px; border-radius: 8px; }
      .btn-ghost { background: #fff; color: var(--slate); border-color: var(--line); }
      .btn-ghost:hover { border-color: #cbd5e1; box-shadow: 0 6px 16px rgba(15,23,42,0.07); }
      .btn-text { background: transparent; border-color: transparent; color: var(--charcoal); padding-left: 6px; padding-right: 6px; }
      .btn-text:hover { transform: none; box-shadow: none; color: var(--slate); }
      .nav-links a.star-link { display: inline-flex; align-items: center; gap: 0.4em; color: #ca8a04; font-weight: 700; }
      .nav-links a.star-link:hover { color: #a16207; }
      .nav-links a.star-link .star-count { font-weight: 600; font-variant-numeric: tabular-nums; white-space: nowrap; }
      .nav-links a.star-link .gh-logo { width: 1.3em; height: 1.3em; color: var(--charcoal); }
      .nav-links a.star-link:hover .gh-logo { color: var(--slate); }
      .nav-links a.nav-discord { display: inline-flex; align-items: center; color: var(--muted); }
      .nav-links a.nav-discord:hover { color: #5865f2; }
      .nav-discord-logo { width: 1.25em; height: 1.25em; }

      /* HERO */
      .hero {
        position: relative; overflow: hidden;
        background:
          radial-gradient(900px 380px at 78% -8%, rgba(163, 230, 53, 0.10), transparent 60%),
          linear-gradient(180deg, #fff 0%, var(--bg-soft) 100%);
        border-bottom: 1px solid var(--line);
      }
      .hero-grid {
        display: grid; grid-template-columns: 1.05fr 1fr; gap: 56px;
        align-items: center; padding: 86px 28px 78px;
      }
      .eyebrow {
        display: inline-block; font-size: 12.5px; font-weight: 600; letter-spacing: 0.04em;
        text-transform: uppercase; color: var(--muted);
        background: #fff; border: 1px solid var(--line); border-radius: 999px;
        padding: 5px 13px; margin-bottom: 22px;
      }
      .eyebrow-short { display: none; }
      .hero h1 { font-size: clamp(38px, 5.4vw, 60px); font-weight: 800; letter-spacing: -0.035em; }
      .hero h1 .accent { color: #4d7c0f; }
      .lede { font-size: 18.5px; color: #334155; max-width: 36em; margin: 22px 0 30px; }
      .cta-row { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
      .proto-row { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 34px; }
      .proto {
        font-size: 12.5px; font-weight: 600; color: var(--charcoal);
        background: #fff; border: 1px solid var(--line); border-radius: 7px; padding: 5px 11px;
      }
      .proto::before { content: '●'; color: var(--lime); font-size: 9px; margin-right: 7px; vertical-align: 1.5px; }

      /* CODE CARD */
      .hero-demo { min-width: 0; }
      .code-card {
        background: var(--slate); border-radius: 14px; overflow: hidden;
        box-shadow: 0 30px 60px -20px rgba(15, 23, 42, 0.35), 0 0 0 1px rgba(15,23,42,0.06);
      }
      .code-head {
        display: flex; align-items: center; gap: 7px; padding: 13px 16px;
        background: #0b1220; border-bottom: 1px solid rgba(255,255,255,0.06);
      }
      .code-head .dot { width: 11px; height: 11px; border-radius: 50%; background: #334155; }
      .code-head .dot:nth-child(1) { background: #475569; }
      .code-file { margin-left: 8px; color: var(--muted-d); font-size: 12.5px; font-family: ui-monospace, monospace; }
      .code-card pre { margin: 0; padding: 20px 22px; overflow-x: auto; }
      .code-card code { font-size: 12.5px; line-height: 1.5; color: #cbd5e1; white-space: pre; }
      .code-card .cm { color: #64748b; }
      .code-card .str { color: #a3e635; }
      .code-card .del { color: #f87171; display: block; }
      .code-card .add { color: #bef264; display: block; }
      .demo-note { font-size: 13.5px; color: var(--muted); margin: 18px 4px 0; line-height: 1.6; }
      .demo-note strong { color: var(--slate); font-weight: 600; }

      /* CORE */
      .core { padding: 92px 28px; }
      .core-inner { max-width: 760px; }
      .core h2 { font-size: clamp(28px, 3.4vw, 40px); font-weight: 800; }
      .core p { font-size: 19px; color: #334155; margin-top: 20px; }
      .core em { color: var(--slate); font-style: normal; font-weight: 600; text-decoration: underline; text-decoration-color: var(--lime); text-decoration-thickness: 2px; text-underline-offset: 3px; }
      .core p a { color: #4d7c0f; text-decoration: underline; text-underline-offset: 3px; }
      .core p a:hover { color: var(--slate); }

      .section-title { font-size: clamp(24px, 3vw, 34px); font-weight: 800; margin-bottom: 38px; }

      /* DIAGRAM */
      .flow { padding: 18px 28px 92px; }
      .diagram {
        display: grid; grid-template-columns: 1fr 0.6fr 1.3fr 0.6fr 1fr; align-items: center; gap: 0;
        background: var(--bg-soft); border: 1px solid var(--line); border-radius: 18px; padding: 38px 26px 76px;
      }
      .col { display: flex; flex-direction: column; gap: 10px; position: relative; }
      .col-label { position: absolute; bottom: calc(100% + 9px); left: 0; right: 0; font-size: 11.5px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted); }
      .node {
        background: #fff; border: 1px solid var(--line); border-radius: 9px;
        padding: 11px 14px; font-size: 13.5px; font-weight: 600; color: var(--charcoal);
        box-shadow: 0 1px 2px rgba(15,23,42,0.04);
      }
      /* Provider tiles read as an OPEN SET of many, a stacked-deck depth distinguishes them
         from the exact six protocol boxes on the left (different kind of thing, not a 1:1 mirror). */
      .col-providers .node:not(.node-more) {
        box-shadow: 0 1px 2px rgba(15,23,42,0.04),
          4px 4px 0 -1px #fff, 4px 4px 0 0 var(--line),
          8px 8px 0 -1px #fff, 8px 8px 0 0 var(--line);
      }
      /* The "+ N more" tile: dashed + muted, clearly "the rest / any provider", not a missing slot. */
      .node-more {
        background: transparent; border-style: dashed; color: var(--muted); box-shadow: none;
      }
      .link-zone svg { width: 100%; height: 150px; }
      .link-zone path { fill: none; stroke: #cbd5e1; stroke-width: 1.6; stroke-dasharray: 5 5; }
      .busbar-box {
        background: var(--slate); border-radius: 14px; padding: 22px 20px; text-align: center;
        box-shadow: 0 18px 40px -16px rgba(15,23,42,0.5);
      }
      .bb-title { display: flex; align-items: center; justify-content: center; gap: 9px; color: #fff; font-weight: 700; font-size: 18px; }
      .bb-tags { display: flex; flex-wrap: wrap; justify-content: center; gap: 6px; margin: 16px 0 12px; }
      .bb-tags span { font-size: 11.5px; font-weight: 600; color: var(--slate); background: var(--lime); border-radius: 6px; padding: 4px 9px; }
      .bb-sub { color: var(--muted-d); font-size: 12px; font-family: ui-monospace, monospace; }
      .link-zone { position: relative; }
      .hop-tls {
        position: absolute; top: 2px; left: 50%; transform: translateX(-50%);
        font-size: 10px; font-weight: 700; letter-spacing: 0.02em; color: var(--muted-d);
        background: var(--bg-soft); padding: 1px 7px; border-radius: 5px; white-space: nowrap; z-index: 2;
      }
      .hook-line { position: absolute; top: calc(100% + 14px); left: 50%; transform: translateX(-50%); width: 2px; height: 34px; overflow: visible; }
      .hook-line line { stroke: #cbd5e1; stroke-width: 2; stroke-dasharray: 5 5; }
      .hook-out { position: absolute; top: 100%; left: 0; right: 0; margin-top: 54px; text-align: center; font-size: 11px; font-weight: 600; color: var(--muted); }

      /* FEATURES */
      .features { padding: 18px 28px 96px; }
      .feature-grid { display: grid; grid-template-columns: repeat(3, 1fr); grid-template-rows: repeat(2, auto 1fr auto); gap: 22px; }
      .feature {
        background: #fff; border: 1px solid var(--line); border-radius: 14px; padding: 26px 24px;
        display: grid; grid-template-rows: subgrid; grid-row: span 3; row-gap: 0;
        transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
      }
      .feature:hover { border-color: #cbd5e1; box-shadow: 0 12px 30px -14px rgba(15,23,42,0.16); transform: translateY(-2px); }
      .feature h3 { font-size: 17.5px; font-weight: 700; margin-bottom: 12px; }
      .feature p { font-size: 14.5px; color: #475569; margin: 0; }
      .feature .enables { font-size: 13.5px; color: var(--charcoal); margin-top: 0; padding-top: 14px; border-top: 1px solid var(--line); }
      .feature .enables span {
        display: inline-block; font-size: 10.5px; font-weight: 700; letter-spacing: 0.06em;
        text-transform: uppercase; color: #4d7c0f; margin-right: 6px;
      }

      /* QUICKSTART */
      .quickstart { background: var(--slate); color: #fff; padding: 88px 0; }
      .qs-grid { display: grid; grid-template-columns: 0.85fr 1.15fr; gap: 56px; align-items: start; }
      /* Grid items must be allowed to shrink below their content's min-content width; otherwise the
         unwrappable `curl … | sh` line stretches the column past the viewport on mobile (h-overflow). */
      .qs-grid > * { min-width: 0; }
      .qs-copy h2 { font-size: clamp(26px, 3.2vw, 36px); font-weight: 800; color: #fff; }
      .qs-copy p { color: #94a3b8; font-size: 16.5px; margin: 18px 0 26px; }
      .qs-copy .btn { background: var(--lime); color: var(--slate); border-color: var(--lime); }
      .qs-copy .btn:hover { box-shadow: 0 8px 24px rgba(163,230,53,0.3); }
      .qs-steps { display: flex; flex-direction: column; gap: 16px; }
      .qs-block { background: #0b1220; border: 1px solid rgba(148,163,184,0.16); border-radius: 12px; overflow: hidden; min-width: 0; max-width: 100%; }
      .qs-tag {
        display: block; font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
        color: var(--lime); padding: 10px 16px 0; font-family: ui-monospace, monospace;
      }
      .qs-block pre { margin: 0; padding: 10px 16px 16px; overflow-x: auto; }
      .qs-block code { font-size: 13px; line-height: 1.65; color: #cbd5e1; white-space: pre; }

      /* TRUST */
      .trust { background: var(--bg-soft); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); padding: 44px 0; }
      .trust-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
      .trust-item { text-align: center; }
      .trust-k { font-size: 18px; font-weight: 800; color: var(--slate); letter-spacing: -0.01em; }
      .trust-v { font-size: 13px; color: var(--muted); margin-top: 4px; }
      .logo-cta { margin-top: 28px; text-align: center; }
      .logo-cta p { font-size: 14px; color: var(--muted); }
      .logo-cta a { color: var(--slate); font-weight: 600; text-decoration: none; border-bottom: 1px solid var(--line); }
      .logo-cta a:hover { border-bottom-color: var(--slate); }

      /* FOOTER */
      .footer { background: #fff; padding: 64px 0 32px; }
      .footer-inner { display: grid; grid-template-columns: 1fr 1.4fr; gap: 48px; padding-bottom: 40px; border-bottom: 1px solid var(--line); }
      .footer-brand { display: flex; gap: 12px; align-items: flex-start; }
      .footer-brand strong { display: block; font-size: 16px; }
      .footer-brand span { font-size: 13.5px; color: var(--muted); }
      .footer-cols { display: grid; grid-template-columns: repeat(4, 1fr); gap: 28px; }
      .footer-cols h4 { font-size: 12px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); margin-bottom: 14px; }
      .footer-cols a { display: block; font-size: 14px; color: var(--charcoal); padding: 4px 0; }
      .footer-cols a:hover { color: var(--slate); }
      .footer-base { display: flex; justify-content: space-between; padding-top: 24px; font-size: 13px; color: var(--muted); flex-wrap: wrap; gap: 10px; }

      /* RESPONSIVE */
      @media (max-width: 900px) {
        /* Two-column sections collapse to one column. These are SEPARATE elements,
           so the selector must be a list (`.a, .b`), not a compound (`.a.b`). */
        .hero-grid, .qs-grid { grid-template-columns: 1fr; gap: 40px; }
        .feature-grid { grid-template-columns: repeat(2, 1fr); grid-template-rows: repeat(3, auto 1fr auto); }
        /* Diagram: collapse to a vertical stack, hide the SVG connectors. */
        .diagram { grid-template-columns: 1fr; gap: 0; padding: 32px 20px; }
        .link-zone { display: none; }
        /* col-label is absolutely positioned above each column; in a stack it would
           overlap the cell above, so make it a normal-flow label. */
        .col { padding-top: 28px; }
        .col-label { position: static; display: block; margin: 0 0 10px; }
        /* hook-line / hook-out are absolute below col-busbar; hide them in the stack. */
        .hook-line, .hook-out { display: none; }
        .col-busbar { padding-bottom: 0; }
        .footer-inner { grid-template-columns: 1fr; gap: 32px; }
        .footer-cols { grid-template-columns: repeat(2, 1fr); }
      }
      @media (max-width: 640px) {
        /* Shorter eyebrow so it stays on one clean line, and smaller code so the
           samples fit without truncating at the card edge on common phones. */
        .eyebrow-full { display: none; }
        .eyebrow-short { display: inline; }
        .code-card pre { padding: 18px 16px; }
        .code-card code { font-size: 11px; }
        .qs-block code { font-size: 12px; }
        .feature-grid { grid-template-columns: 1fr; grid-template-rows: repeat(6, auto 1fr auto); }
        .trust-grid { grid-template-columns: repeat(2, 1fr); }
        .hero-grid { padding: 48px 20px 44px; }
        .quickstart { padding: 56px 0; }
        .core { padding: 64px 20px; }
        .core p { font-size: 17px; }
        .flow { padding: 8px 20px 64px; }
        .features { padding: 8px 20px 72px; }
        .section-title { margin-bottom: 28px; }
        .hero h1 { font-size: clamp(30px, 9vw, 42px); }
        .lede { font-size: 16px; }
        /* CTA buttons stack full-width for easy tap targets. */
        .cta-row { flex-direction: column; align-items: stretch; gap: 10px; }
        .cta-row .btn { width: 100%; }
        .footer-base { flex-direction: column; gap: 6px; }
      }
      @media (max-width: 420px) {
        .eyebrow { font-size: 11px; letter-spacing: 0.03em; }
        .wrap { padding: 0 16px; }
        .hero-grid { padding: 40px 16px 36px; }
        .diagram { padding: 24px 16px; }
        .footer-cols { grid-template-columns: 1fr; }
        .trust-grid { grid-template-columns: 1fr; }
      }
    </style>
  </body>
</html>
