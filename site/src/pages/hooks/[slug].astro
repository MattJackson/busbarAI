---
// Per-hook detail page. Generated only for hooks whose own page is their card
// link (href === `/hooks/${slug}`) — currently Headroom. Smart Router links to
// its blog post and Ideas aren't linked, so neither gets a page here. Hook data
// is shared with the store index via src/data/hooks.ts.
import PageLayout from '../../layouts/PageLayout.astro';
import { hooks, kindLabel, type Hook } from '../../data/hooks';

export function getStaticPaths() {
  return hooks
    .filter((h) => h.href === `/hooks/${h.slug}` && h.detail)
    .map((h) => ({ params: { slug: h.slug }, props: { hook: h } }));
}

interface Props { hook: Hook }
const { hook } = Astro.props;
const statusClass = `status-${hook.status.toLowerCase().replace(' ', '-')}`;

// Inline logos for the spotlight link row (24x24 viewBox). Icon, not button.
const ICONS: Record<string, string> = {
  web: '<circle cx="12" cy="12" r="9.5" fill="none" stroke="currentColor" stroke-width="1.6"/><path d="M12 2.5c2.6 2.4 3.7 6 3.7 9.5s-1.1 7.1-3.7 9.5c-2.6-2.4-3.7-6-3.7-9.5S9.4 4.9 12 2.5ZM2.6 9h18.8M2.6 15h18.8" fill="none" stroke="currentColor" stroke-width="1.6"/>',
  github: '<path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7 0-.7 0-.7 1.2 0 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.8 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 5 18.3 5.3 18.3 5.3c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.5-2.7 5.5-5.3 5.8.4.4.8 1.1.8 2.2v3.3c0 .4.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z"/>',
  developer: '<path d="M12 12a5 5 0 1 0 0-10 5 5 0 0 0 0 10Zm0 2c-5 0-9 2.7-9 6v2h18v-2c0-3.3-4-6-9-6Z"/>',
  install: '<path d="M12 3v11m0 0 4-4m-4 4-4-4M4 19h16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>',
  discord: '<path d="M20.3 4.4A19.8 19.8 0 0 0 15.4 3l-.2.4a18.3 18.3 0 0 1 5.5 2.8 18.3 18.3 0 0 0-15.4 0 18.3 18.3 0 0 1 5.5-2.8L10.6 3a19.8 19.8 0 0 0-4.9 1.4C2.5 9 1.6 13.6 2.1 18a19.9 19.9 0 0 0 6 3l.5-.7c-.7-.3-1.3-.6-1.9-1l.5-.3a14.2 14.2 0 0 0 12.2 0l.5.3c-.6.4-1.2.7-1.9 1l.5.7a19.9 19.9 0 0 0 6-3c.6-5.1-.9-9.7-3.7-13.6ZM8.9 15.3c-1 0-1.7-.9-1.7-1.9s.8-1.9 1.7-1.9 1.8.9 1.7 1.9c0 1-.8 1.9-1.7 1.9Zm6.2 0c-1 0-1.7-.9-1.7-1.9s.8-1.9 1.7-1.9 1.8.9 1.7 1.9c0 1-.7 1.9-1.7 1.9Z"/>',
};
---

<PageLayout
  title={`${hook.name} — a Busbar hook`}
  description={hook.body.replace(/<[^>]+>/g, '')}
>
  <p class="kicker"><a href="/hooks/">Hook Store</a> · {kindLabel[hook.kind]}</p>

  <!-- OUR side: our page, our hook. Top-right actions point to our GitHub and
       jump to how to install it. Their project gets its own block below. -->
  <div class="hook-head">
    <h1>{hook.name}</h1>
    {(hook.hookRepo || hook.install) && (
      <div class="hook-actions">
        {hook.hookRepo && (
          <a class="hook-action" href={hook.hookRepo} target="_blank" rel="noopener" title="Busbar on GitHub" aria-label="Busbar on GitHub">
            <svg width="17" height="17" viewBox="0 0 24 24" aria-hidden="true" set:html={ICONS.github}></svg>
            <span>GitHub</span>
          </a>
        )}
        {hook.install && (
          <a class="hook-action" href="#install" title="How to install" aria-label="How to install">
            <svg width="17" height="17" viewBox="0 0 24 24" aria-hidden="true" set:html={ICONS.install}></svg>
            <span>Install</span>
          </a>
        )}
      </div>
    )}
  </div>

  <p class="intro">
    <span class="hook-tag">{hook.tagline}</span>
    <span class:list={['hook-status', statusClass]}>{hook.status}</span>
  </p>

  {hook.detail?.map((p) => <p set:html={p} />)}

  {hook.install && (
    <section class="install" id="install">
      <h2>Install it</h2>
      <p set:html={hook.install.note}></p>
      {hook.install.code && <pre class="install-code"><code>{hook.install.code}</code></pre>}
      <p class="install-foot">
        See the <a href="/docs/hooks/">hooks docs</a> for the full config shape and lifecycle.
      </p>
    </section>
  )}

  {hook.spotlight && (
    <section class="spotlight">
      <p class="spotlight-eyebrow">Built on open source</p>
      <h2 class="spotlight-title">{hook.spotlight.project}</h2>
      <p class="spotlight-blurb" set:html={hook.spotlight.blurb}></p>
      <div class="spotlight-links">
        {hook.spotlight.links.map((l) => (
          <a class="spotlight-link" href={l.url} target="_blank" rel="noopener" title={l.label} aria-label={l.label}>
            <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true" set:html={ICONS[l.icon]}></svg>
            <span>{l.label}</span>
          </a>
        ))}
      </div>
      <p class="spotlight-foot">
        Busbar wraps {hook.spotlight.project} as a hook so it runs on the request path — all credit
        for the compression itself goes to its authors. Not affiliated with Busbar.
      </p>
    </section>
  )}

  {!hook.spotlight && hook.note && <p class="note" set:html={hook.note} />}

  <p class="hook-back"><a href="/hooks/">← Back to the Hook Store</a></p>

  <style is:global>
    /* OUR header row: hook name left, our-side actions (GitHub, Install) top-right. */
    .hook-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
    }
    .hook-actions { display: flex; gap: 8px; flex-shrink: 0; padding-top: 4px; }
    .page-doc .hook-action {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 9px;
      padding: 8px 13px;
      font-size: 13.5px;
      font-weight: 700;
      color: var(--charcoal);
      text-decoration: none;
      transition: border-color 0.15s, box-shadow 0.15s, transform 0.12s, color 0.15s;
    }
    .page-doc .hook-action:hover {
      border-color: #cbd5e1;
      box-shadow: 0 8px 20px -12px rgba(15, 23, 42, 0.16);
      transform: translateY(-1px);
      color: var(--slate);
    }
    .hook-action svg { width: 17px; height: 17px; fill: currentColor; }

    /* INSTALL — OUR side: what we do, how to get it, how to install it. */
    .page-doc .install {
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 24px 26px 20px;
      margin: 36px 0 8px;
      background: var(--bg-soft);
      /* The #install anchor lives on this section, so the scroll offset (sticky
         nav 64px + a little air) must sit here, not on the inner h2. */
      scroll-margin-top: 80px;
    }
    .page-doc .install h2 {
      margin: 0 0 12px;
      font-size: 20px;
    }
    .page-doc .install p { margin: 0 0 14px; }
    .page-doc .install-code {
      background: var(--slate);
      color: #cbd5e1;
      border-radius: 10px;
      padding: 16px 18px;
      overflow-x: auto;
      margin: 0 0 14px;
    }
    .page-doc .install-code code {
      background: none;
      border: 0;
      padding: 0;
      color: inherit;
      font-size: 13px;
      line-height: 1.6;
      white-space: pre;
    }
    .page-doc .install-foot { font-size: 13.5px; color: var(--muted); margin: 0; }

    /* The tagline + status badge sit on one line under the H1, inside .intro. */
    .page-doc .intro {
      display: flex;
      align-items: baseline;
      flex-wrap: wrap;
      gap: 12px;
    }
    .hook-tag {
      font-size: 17px;
      font-weight: 600;
      color: #4d7c0f;
    }
    .hook-status {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .hook-status.status-available { color: #4d7c0f; }
    .hook-status.status-coming-soon { color: #b45309; }
    .hook-status.status-example { color: #b45309; }
    .hook-status.status-idea { color: var(--muted); }
    .hook-back { margin-top: 28px; }
    .hook-back a { font-weight: 700; }

    /* COMMUNITY SPOTLIGHT — a generous credit block for the OSS project this hook
       wraps. Lime-tinted card so it reads as a shout-out, not fine print. */
    .page-doc .spotlight {
      background: #f7fee7;
      border: 1px solid #d9f99d;
      border-radius: 16px;
      padding: 28px 28px 24px;
      margin: 40px 0 8px;
    }
    .spotlight-eyebrow {
      font-size: 11.5px;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #4d7c0f;
      margin: 0 0 8px;
    }
    .page-doc .spotlight-title {
      font-size: 22px;
      font-weight: 800;
      color: var(--slate);
      margin: 0 0 12px;
      scroll-margin-top: 84px;
    }
    .page-doc .spotlight-blurb {
      font-size: 15.5px;
      color: #334155;
      line-height: 1.7;
      margin: 0 0 18px;
    }
    .spotlight-links {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }
    .page-doc .spotlight-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: #fff;
      border: 1px solid #d9f99d;
      border-radius: 9px;
      padding: 9px 14px;
      font-size: 14px;
      font-weight: 700;
      color: #4d7c0f;
      text-decoration: none;
      transition: border-color 0.15s, box-shadow 0.15s, transform 0.12s;
    }
    .page-doc .spotlight-link:hover {
      border-color: #bef264;
      box-shadow: 0 8px 20px -12px rgba(15, 23, 42, 0.18);
      transform: translateY(-1px);
      color: var(--slate);
    }
    .spotlight-link svg { width: 18px; height: 18px; fill: currentColor; flex-shrink: 0; }
    .page-doc .spotlight-foot {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.6;
      margin: 18px 0 0;
    }
  </style>
</PageLayout>
