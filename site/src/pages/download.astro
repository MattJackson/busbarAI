---
// Busbar download page, standalone Astro page matching homepage nav + footer styling.
// All binary links are STATIC, version-less GitHub "latest" asset URLs:
//   …/releases/latest/download/busbar-<target>.tar.gz   (.zip for Windows)
// so they always resolve to the newest release with no JavaScript or API calls.
// The asset names are kept version-less by .github/workflows/release.yml (archive: busbar-$target).
import glyphPrimary from '../assets/busbar-primary.svg';
import dockerMark from '../assets/docker.svg';
// Crate version, synced from the repo Cargo.toml into src/release.json by sync-docs.mjs
// (runs before every dev/build). Importing keeps the read inside site/, robust in astro build.
import release from '../release.json';
import Nav from '../components/Nav.astro';
import Analytics from '../components/Analytics.astro';

const GITHUB = 'https://github.com/MattJackson/busbarAI';
const REL = `${GITHUB}/releases/latest/download`;
const YEAR = new Date().getFullYear();
const version = release.version || '';

const ORG = { '@context': 'https://schema.org', '@type': 'Organization', name: 'Busbar', url: 'https://getbusbar.com', logo: 'https://getbusbar.com/favicon.svg', sameAs: ['https://github.com/MattJackson/busbarAI'] };
const WEBSITE = { '@context': 'https://schema.org', '@type': 'WebSite', name: 'Busbar', url: 'https://getbusbar.com' };
const SOFTWARE = { '@context': 'https://schema.org', '@type': 'SoftwareApplication', name: 'Busbar', applicationCategory: 'DeveloperApplication', operatingSystem: 'Linux, macOS, Windows', offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' }, url: 'https://getbusbar.com', description: 'The reliability and fidelity layer for multi-model AI traffic, lossless cross-protocol translation, fault-aware circuit breaking, and in-flight failover in one static Rust binary.' };

// Each archive contains the single `busbar` binary. Targets mirror release.yml's matrix.
const groups = [
  {
    os: 'macos',
    name: 'macOS',
    builds: [
      { label: 'Apple Silicon', sub: 'aarch64', file: 'busbar-aarch64-apple-darwin.tar.gz' },
      { label: 'Intel', sub: 'x86_64', file: 'busbar-x86_64-apple-darwin.tar.gz' },
    ],
  },
  {
    os: 'linux',
    name: 'Linux',
    builds: [
      { label: 'x86_64', sub: 'gnu', file: 'busbar-x86_64-unknown-linux-gnu.tar.gz' },
      { label: 'ARM64', sub: 'aarch64 · gnu', file: 'busbar-aarch64-unknown-linux-gnu.tar.gz' },
    ],
  },
  {
    os: 'windows',
    name: 'Windows',
    builds: [
      { label: 'x86_64', sub: 'msvc · .zip', file: 'busbar-x86_64-pc-windows-msvc.zip' },
    ],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Download Busbar</title>
    <meta
      name="description"
      content="Download Busbar: one static Rust binary for Linux, macOS, and Windows (Intel and ARM). No runtime, no sidecar. Install with one command or grab the binary directly."
    />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="color-scheme" content="light" />
    <link rel="canonical" href={new URL(Astro.url.pathname, "https://getbusbar.com")} />
    <Analytics />
    <script type="application/ld+json" set:html={JSON.stringify(ORG)} />
    <script type="application/ld+json" set:html={JSON.stringify(WEBSITE)} />
    <script type="application/ld+json" set:html={JSON.stringify(SOFTWARE)} />
  </head>
  <body>
    <Nav />

    <main class="dl-wrap">
      <div class="dl-head">
        <h1>Download Busbar</h1>
        <p class="dl-sub">
          One static Rust binary, no runtime, no sidecar, no interpreter in the request path.
          Pick your platform below, or use the one-line installer.
        </p>
        {version && (
          <p class="dl-version">
            Latest release <strong>v{version}</strong>
            <span class="dot">·</span>
            <a href="/docs/changelog/">Full changelog →</a>
          </p>
        )}
      </div>

      <!-- Docker -->
      <section class="dl-install">
        <a class="dl-install-tag dl-tag-link" href="https://hub.docker.com/r/getbusbar/busbar">
          <img src={dockerMark.src} alt="" width="15" height="15" />
          Docker · multi-arch (amd64 + arm64)
        </a>
        <div class="dl-cmd">
          <code>docker pull getbusbar/busbar</code>
          <button class="dl-copy" data-copy="docker pull getbusbar/busbar" aria-label="Copy docker pull command">Copy</button>
        </div>
        <p class="dl-install-note">
          A <code>FROM scratch</code> image: the static binary plus the provider catalog, ~5 MB
          compressed. Pin an exact version (<code>getbusbar/busbar:{version || 'latest'}</code>) or ride
          <code>latest</code>; images carry a verifiable build-provenance attestation
          (<a href="https://hub.docker.com/r/getbusbar/busbar">Docker Hub</a>, also on GHCR).
          Then follow <a href="/docs/getting-started/">Getting Started</a> to configure and run it.
        </p>
      </section>

      <!-- One-line installer -->
      <section class="dl-install">
        <div class="dl-install-tag">One-line install · macOS &amp; Linux</div>
        <div class="dl-cmd">
          <code>curl -fsSL https://getbusbar.com/install.sh | sh</code>
          <button class="dl-copy" data-copy="curl -fsSL https://getbusbar.com/install.sh | sh" aria-label="Copy install command">Copy</button>
        </div>
        <p class="dl-install-note">
          Drops <code>busbar</code> and <code>providers.yaml</code> into the current directory,
          no sudo, no global install. Then follow <a href="/docs/getting-started/">Getting Started</a>.
        </p>
      </section>

      <!-- Direct binary downloads -->
      <h2 class="dl-h2">Or grab the binary directly</h2>
      <div class="dl-grid">
        {groups.map((g) => (
          <div class="dl-card" data-os={g.os}>
            <div class="dl-card-head">
              <span class="dl-os">{g.name}</span>
              <span class="dl-detected">Your platform</span>
            </div>
            <div class="dl-builds">
              {g.builds.map((b) => (
                <a class="dl-btn" href={`${REL}/${b.file}`} download>
                  <span class="dl-btn-label">{b.label}</span>
                  <span class="dl-btn-sub">{b.sub}</span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>

      <p class="dl-foot-note">
        Each archive contains the single <code>busbar</code> binary. You'll also need the
        provider catalog, <a href="/providers.yaml">providers.yaml</a>, which the installer
        fetches automatically. Builds are produced by the
        <a href={`${GITHUB}/actions/workflows/release.yml`}>release workflow</a> and attached to
        each tagged release. Source &amp; checksums: <a href={`${GITHUB}/releases/latest`}>latest release</a>.
      </p>
    </main>

    <footer class="footer">
      <div class="wrap footer-inner">
        <div class="footer-brand">
          <img src={glyphPrimary.src} alt="" width="26" height="26" />
          <div>
            <strong>Busbar</strong>
            <span>Your AI Control Plane.</span>
          </div>
        </div>
        <nav class="footer-cols">
          <div>
            <h4>Docs</h4>
            <a href="/docs/getting-started/">Getting Started</a>
            <a href="/docs/why-busbar/">Why Busbar</a>
            <a href="/faq/">FAQ</a>
            <a href="/build/">Config builder</a>
            <a href="/docs/reliability/">Reliability</a>
            <a href="/docs/routing/">Routing</a>
            <a href="/docs/benchmark/">Benchmark</a>
          </div>
          <div>
            <h4>Reference</h4>
            <a href="/docs/protocols/">Protocols</a>
            <a href="/docs/configuration/">Configuration</a>
            <a href="/docs/security/">Security</a>
            <a href="/docs/providers/">Providers</a>
          </div>
          <div>
            <h4>Project</h4>
            <a href="/download/">Download</a>
            <a href="/blog/">Blog</a>
            <a href="/docs/changelog/">Changelog</a>
            <a href={GITHUB}>GitHub</a>
            <a href={`${GITHUB}/blob/main/LICENSE`}>Apache-2.0</a>
            <a href="/llms.txt">llms.txt</a>
          </div>
          <div>
            <h4>Legal</h4>
            <a href="/privacy/">Privacy Policy</a>
            <a href="/terms/">Terms of Service</a>
          </div>
        </nav>
      </div>
      <div class="wrap footer-base">
        <span>© {YEAR} Busbar, Inc.</span>
        <span>One endpoint. Every protocol, every capability. Losslessly.</span>
      </div>
    </footer>

    <script is:inline>
      // Progressive enhancement only: highlight the visitor's likely platform.
      // Every download link is a plain static URL and works with JS disabled.
      (function () {
        var ua = (navigator.userAgent || '') + ' ' + (navigator.platform || '');
        var os = /Win/i.test(ua) ? 'windows' : /Mac|iPhone|iPad/i.test(ua) ? 'macos'
          : /Linux|Android/i.test(ua) ? 'linux' : '';
        if (os) {
          var card = document.querySelector('.dl-card[data-os="' + os + '"]');
          if (card) card.classList.add('is-detected');
        }
        document.querySelectorAll('.dl-copy').forEach(function (btn) {
          btn.addEventListener('click', function () {
            navigator.clipboard && navigator.clipboard.writeText(btn.dataset.copy);
            var t = btn.textContent; btn.textContent = 'Copied'; setTimeout(function () { btn.textContent = t; }, 1400);
            // Custom Plausible goal: strong install-intent signal (copied the one-line installer).
            window.plausible && window.plausible('Copy install command');
          });
        });
      })();
    </script>

    <style is:global>
      :root {
        color-scheme: light;
        --slate: #0f172a;
        --charcoal: #1e293b;
        --lime: #a3e635;
        --ink: #0b1220;
        --line: #e2e8f0;
        --muted: #64748b;
        --muted-d: #94a3b8;
        --bg: #ffffff;
        --bg-soft: #f8fafc;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--slate);
        font-family: ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto,
          Helvetica, Arial, sans-serif;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      .wrap { width: 100%; max-width: 1120px; margin: 0 auto; padding: 0 28px; }
      a { color: inherit; text-decoration: none; }
      h1, h2, h3, h4 { letter-spacing: -0.02em; line-height: 1.1; margin: 0; }

      /* Nav styling lives in the shared Nav.astro component (single source of truth). */

      /* DOWNLOAD */
      .dl-wrap { min-height: calc(100vh - 64px - 200px); padding: 72px 28px 96px; max-width: 980px; margin: 0 auto; }
      .dl-head { text-align: center; max-width: 680px; margin: 0 auto 44px; }
      .dl-head h1 { font-size: clamp(30px, 4.4vw, 46px); font-weight: 800; color: var(--slate); margin-bottom: 16px; }
      .dl-sub { font-size: 17.5px; color: #475569; line-height: 1.65; margin: 0 0 18px; }
      .dl-version { font-size: 14px; color: var(--muted); margin: 0; }
      .dl-version strong { color: var(--slate); }
      .dl-version .dot { margin: 0 10px; color: var(--muted-d); }
      .dl-version a { color: #4d7c0f; font-weight: 600; }
      .dl-version a:hover { color: var(--slate); }

      .dl-install {
        background: var(--bg-soft); border: 1px solid var(--line); border-radius: 16px;
        padding: 24px 26px; max-width: 720px; margin: 0 auto 56px;
      }
      .dl-install-tag {
        display: inline-block; font-size: 10.5px; font-weight: 700; letter-spacing: 0.06em;
        text-transform: uppercase; color: #4d7c0f; margin-bottom: 12px;
      }
      .dl-tag-link {
        display: inline-flex; align-items: center; gap: 6px; text-decoration: none;
      }
      .dl-tag-link:hover { color: var(--slate); }
      .dl-tag-link img { display: block; }
      .dl-cmd {
        display: flex; align-items: center; justify-content: space-between; gap: 14px;
        background: var(--ink); border-radius: 10px; padding: 14px 16px;
      }
      .dl-cmd code {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 14px;
        color: #e2e8f0; overflow-x: auto; white-space: nowrap;
      }
      .dl-copy {
        flex: none; background: rgba(255,255,255,0.08); color: #e2e8f0; border: 1px solid rgba(255,255,255,0.16);
        border-radius: 7px; padding: 6px 12px; font-size: 12.5px; font-weight: 600; cursor: pointer;
        transition: background 0.15s;
      }
      .dl-copy:hover { background: rgba(255,255,255,0.16); }
      .dl-install-note { font-size: 13.5px; color: var(--muted); margin: 14px 0 0; }
      .dl-install-note code { font-family: ui-monospace, monospace; font-size: 12.5px; background: #eef2f7; padding: 1px 5px; border-radius: 4px; color: var(--charcoal); }
      .dl-install-note a.dl-foot-note a { color: #4d7c0f; text-decoration: underline; text-underline-offset: 3px; }
      .dl-install-note a:hover.dl-foot-note a:hover { color: var(--slate); }

      .dl-h2 { font-size: 20px; font-weight: 700; color: var(--slate); text-align: center; margin: 0 0 24px; }
      .dl-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; align-items: start; }
      .dl-card {
        background: #fff; border: 1px solid var(--line); border-radius: 14px; padding: 22px 20px;
        transition: border-color 0.15s, box-shadow 0.15s;
      }
      .dl-card.is-detected { border-color: var(--lime); box-shadow: 0 0 0 3px rgba(163,230,53,0.18); }
      .dl-card-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
      .dl-os { font-size: 16px; font-weight: 800; color: var(--slate); }
      .dl-detected {
        display: none; font-size: 10px; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase;
        color: #4d7c0f; background: #f0fdd4; border-radius: 5px; padding: 3px 8px;
      }
      .dl-card.is-detected .dl-detected { display: inline-block; }
      .dl-builds { display: flex; flex-direction: column; gap: 10px; }
      .dl-btn {
        display: flex; align-items: baseline; justify-content: space-between; gap: 10px;
        border: 1px solid var(--line); border-radius: 9px; padding: 12px 14px;
        background: var(--bg-soft); transition: border-color 0.15s, background 0.15s, transform 0.12s;
      }
      .dl-btn:hover { border-color: #cbd5e1; background: #fff; transform: translateY(-1px); }
      .dl-btn-label { font-size: 14px; font-weight: 700; color: var(--slate); }
      .dl-btn-sub { font-size: 11.5px; color: var(--muted); font-family: ui-monospace, monospace; }
      .dl-foot-note { font-size: 13px; color: var(--muted); line-height: 1.7; max-width: 720px; margin: 40px auto 0; text-align: center; }
      .dl-foot-note code { font-family: ui-monospace, monospace; font-size: 12px; background: #eef2f7; padding: 1px 5px; border-radius: 4px; color: var(--charcoal); }

      /* FOOTER */
      .footer { background: #fff; padding: 64px 0 32px; border-top: 1px solid var(--line); }
      .footer-inner { display: grid; grid-template-columns: 1fr 1.4fr; gap: 48px; padding-bottom: 40px; border-bottom: 1px solid var(--line); }
      .footer-brand { display: flex; gap: 12px; align-items: flex-start; }
      .footer-brand strong { display: block; font-size: 16px; }
      .footer-brand span { font-size: 13.5px; color: var(--muted); }
      .footer-cols { display: grid; grid-template-columns: repeat(4, 1fr); gap: 28px; }
      .footer-cols h4 { font-size: 12px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); margin-bottom: 14px; }
      .footer-cols a { display: block; font-size: 14px; color: var(--charcoal); padding: 4px 0; text-decoration: none; }
      .footer-cols a:hover { color: var(--slate); }
      .footer-base { display: flex; justify-content: space-between; padding-top: 24px; font-size: 13px; color: var(--muted); flex-wrap: wrap; gap: 10px; }

      /* RESPONSIVE */
      @media (max-width: 900px) {
        .dl-grid { grid-template-columns: 1fr; max-width: 440px; margin: 0 auto; }
        .footer-inner { grid-template-columns: 1fr; gap: 32px; }
        .footer-cols { grid-template-columns: repeat(2, 1fr); }
      }
      @media (max-width: 640px) {
        html { overflow-x: clip; }
        .footer-cols { grid-template-columns: 1fr 1fr; }
        .dl-wrap { padding: 48px 16px 72px; }
        /* Install command row: stack code above copy button on narrow screens so
           neither overflows the card */
        .dl-cmd {
          flex-direction: column;
          align-items: stretch;
          gap: 10px;
        }
        .dl-cmd code { font-size: 12px; overflow-x: auto; display: block; }
        .dl-copy { align-self: flex-end; }
        /* Download grid full-width on phones */
        .dl-grid { max-width: 100%; }
      }
      @media (max-width: 420px) {
        .wrap { padding: 0 16px; }
      }
    </style>
  </body>
</html>
